#!/bin/sh
# memory-hive — single entry point CLI for managing your hive's agents.
#
# Usage:
#   memory-hive add <name> [--role <template|path>]
#   memory-hive list
#   memory-hive archive <name>
#   memory-hive role <name>
#   memory-hive rename <old> <new>
#   memory-hive register
#   memory-hive doctor
#   memory-hive help
#
# <template> is one of: coder, reviewer, researcher, writer, planner
# <path> is a path to a markdown file; its contents become the role text.
#
# Install location is auto-detected in the same way create-agent.sh does:
#   1. $MEMORY_HIVE_DIR if set
#   2. The dir this script lives in, if it contains hive/
#   3. $HOME/.memory-hive

set -e

# --- locate install root -----------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
if [ -n "${MEMORY_HIVE_DIR:-}" ]; then
    INSTALL_DIR="$MEMORY_HIVE_DIR"
elif [ -n "$SCRIPT_DIR" ] && [ -d "$SCRIPT_DIR/hive" ]; then
    INSTALL_DIR="$SCRIPT_DIR"
else
    INSTALL_DIR="$HOME/.memory-hive"
fi
HIVE_DIR="$INSTALL_DIR/hive"
AGENTS_DIR="$HIVE_DIR/agents"
ROLES_DIR="$INSTALL_DIR/templates/roles"
CREATE_AGENT="$INSTALL_DIR/create-agent.sh"

# --- helpers -----------------------------------------------------------------

_mh_die() { printf 'ERROR: %s\n' "$1" >&2; exit 1; }

_mh_require_install() {
    if [ ! -d "$HIVE_DIR" ]; then
        _mh_die "Memory Hive is not installed at $INSTALL_DIR. Run the installer first."
    fi
}

# _mh_sanitize_name <raw> -> prints sanitized name to stdout.
# Mirrors install.sh's _sanitize_name so wizard + CLI agree on the rules.
_mh_sanitize_name() {
    _raw="$1"
    _name="$(printf '%s' "$_raw" \
        | tr ' ' '-' \
        | tr '[:upper:]' '[:lower:]' \
        | tr -cd 'a-z0-9-' \
        | sed -e 's/-\{2,\}/-/g' -e 's/^-//' -e 's/-$//')"
    _name="$(printf '%s' "$_name" | cut -c1-32)"
    _name="$(printf '%s' "$_name" | sed -e 's/-$//')"
    case "$_name" in
        ""|*[!a-z0-9-]*)
            printf ''
            return
            ;;
    esac
    printf '%s' "$_name"
}

# _mh_resolve_role <input> -> prints role text to stdout.
# <input> can be a template name (coder/reviewer/...) or a path to a file.
# Empty input prints nothing.
_mh_resolve_role() {
    _role="$1"
    [ -z "$_role" ] && return 0
    # File path (absolute or contains a slash) → read the file verbatim.
    case "$_role" in
        /*|./*|../*|*/*)
            if [ -f "$_role" ]; then
                cat "$_role"
                return 0
            fi
            _mh_die "Role file not found: $_role"
            ;;
    esac
    # Template name → look under $ROLES_DIR/<name>.md.
    _tpl="$ROLES_DIR/$_role.md"
    if [ -f "$_tpl" ]; then
        cat "$_tpl"
        return 0
    fi
    _mh_die "Unknown role '$_role'. Known templates: $(_mh_list_templates). Or pass a path to a .md file."
}

_mh_list_templates() {
    _out=""
    if [ -d "$ROLES_DIR" ]; then
        for _f in "$ROLES_DIR"/*.md; do
            [ -f "$_f" ] || continue
            _n="$(basename "$_f" .md)"
            if [ -z "$_out" ]; then _out="$_n"; else _out="$_out, $_n"; fi
        done
    fi
    printf '%s' "$_out"
}

# _mh_list_silos: print newline-separated list of non-archived, non-dotfile
# silo names under $AGENTS_DIR. Empty if there are none.
_mh_list_silos() {
    [ -d "$AGENTS_DIR" ] || return 0
    for _p in "$AGENTS_DIR"/*; do
        [ -d "$_p" ] || continue
        _n="$(basename "$_p")"
        case "$_n" in
            _archived|.*) continue ;;
        esac
        printf '%s\n' "$_n"
    done
}

# _mh_extract_role <context-file>
# Print the first non-blank, non-placeholder line under "## Role" and continue
# printing lines until the next "## " heading or blank line. Squashes
# intermediate newlines into single spaces so the result fits a table cell.
# Prints empty if no usable role text was found.
_mh_extract_role() {
    _cf="$1"
    [ -f "$_cf" ] || return 0
    awk '
        BEGIN { inrole = 0; buf = ""; done = 0 }
        /^## Role$/ { inrole = 1; next }
        inrole == 1 && /^## / { done = 1; exit }
        inrole == 1 {
            # Skip the placeholder prompt lines like "(What is this agent...)".
            if ($0 ~ /^[[:space:]]*\([^)]*\)[[:space:]]*$/) next
            if ($0 ~ /^[[:space:]]*$/) {
                if (buf != "") { done = 1; exit }
                next
            }
            line = $0
            sub(/^[[:space:]]+/, "", line)
            sub(/[[:space:]]+$/, "", line)
            if (buf == "") { buf = line } else { buf = buf " " line }
        }
        END {
            # Cap at ~140 chars so the AGENTS.md table stays tidy.
            if (length(buf) > 140) { buf = substr(buf, 1, 137) "..." }
            if (buf != "") print buf
        }
    ' "$_cf"
}

# mh_register: rewrite $HIVE_DIR/registry/AGENTS.md's auto-generated block
# with the current on-disk roster and, if the shipped SKILLS_CATALOG.md is
# still in place, replace it with a short user-maintained note.
#
# Never aborts the caller: best-effort, returns 0 even when the hive is
# missing (so wrappers like `mh_add` can call it unconditionally).
mh_register() {
    _reg_dir="$HIVE_DIR/registry"
    _reg_agents="$_reg_dir/AGENTS.md"
    _reg_skills="$_reg_dir/SKILLS_CATALOG.md"

    # If the hive isn't there yet there's nothing to register. Treat as no-op.
    [ -d "$HIVE_DIR" ] || return 0

    mkdir -p "$_reg_dir" 2>/dev/null || return 0

    _start_marker="<!-- memory-hive:agents:start -->"
    _end_marker="<!-- memory-hive:agents:end -->"

    # Build the table body in a temp file.
    _tbl="$_reg_dir/.agents-table.$$"
    {
        printf '%s\n' "$_start_marker"
        printf '<!-- Auto-generated by `memory-hive register`. Do not edit by hand; edit silo context.md files instead. -->\n'
        printf '\n'
        printf '| Agent | Role |\n'
        printf '|---|---|\n'
        _mh_list_silos | sort | while IFS= read -r _aid; do
            [ -n "$_aid" ] || continue
            _role="$(_mh_extract_role "$AGENTS_DIR/$_aid/context.md")"
            [ -n "$_role" ] || _role="_(no role set)_"
            # Escape pipes in the role text so the markdown table doesn't break.
            _role_esc="$(printf '%s' "$_role" | sed 's/|/\\|/g')"
            printf '| %s | %s |\n' "$_aid" "$_role_esc"
        done
        printf '%s\n' "$_end_marker"
    } > "$_tbl" 2>/dev/null || { rm -f "$_tbl"; return 0; }

    if [ -f "$_reg_agents" ] \
        && grep -q -F "$_start_marker" "$_reg_agents" 2>/dev/null \
        && grep -q -F "$_end_marker" "$_reg_agents" 2>/dev/null; then
        # Splice: replace everything between the markers, preserving content
        # above and below. POSIX awk reads the replacement from a file.
        _tmp="$_reg_agents.mhreg.$$"
        awk -v start="$_start_marker" -v end="$_end_marker" -v blockfile="$_tbl" '
            BEGIN { inblock = 0 }
            {
                if (inblock == 0 && index($0, start) > 0) {
                    while ((getline line < blockfile) > 0) print line
                    close(blockfile)
                    inblock = 1
                    next
                }
                if (inblock == 1) {
                    if (index($0, end) > 0) { inblock = 0 }
                    next
                }
                print
            }
        ' "$_reg_agents" > "$_tmp" 2>/dev/null \
            && mv "$_tmp" "$_reg_agents" 2>/dev/null \
            || { rm -f "$_tmp"; rm -f "$_tbl"; return 0; }
    else
        # File missing or no markers — create or append.
        if [ ! -f "$_reg_agents" ]; then
            {
                printf '# Agent Registry\n\n'
                printf 'Current roster. The table below is auto-generated from `hive/agents/*/context.md` by\n'
                printf '`memory-hive register`. Edit the silo files, not this table.\n\n'
                cat "$_tbl"
                printf '\n'
            } > "$_reg_agents" 2>/dev/null || { rm -f "$_tbl"; return 0; }
        else
            # Append markers + table at the end; keep existing human content
            # intact so nothing is lost.
            _tmp="$_reg_agents.mhreg.$$"
            {
                cat "$_reg_agents"
                # Ensure trailing newline before appending.
                _last="$(tail -c 1 "$_reg_agents" 2>/dev/null || printf '')"
                if [ "$_last" != "" ] && [ "$_last" != "
" ]; then
                    printf '\n'
                fi
                printf '\n'
                cat "$_tbl"
                printf '\n'
            } > "$_tmp" 2>/dev/null \
                && mv "$_tmp" "$_reg_agents" 2>/dev/null \
                || { rm -f "$_tmp"; rm -f "$_tbl"; return 0; }
        fi
    fi
    rm -f "$_tbl"

    # Skills catalog: if the file still looks like the shipped template,
    # replace it with a short pointer note. Detect by looking for the
    # canonical headings the shipped template uses. Anything else (user has
    # customized it) → leave strictly alone.
    if [ -f "$_reg_skills" ]; then
        if grep -q '^# Skills Catalog$' "$_reg_skills" 2>/dev/null \
            && grep -q 'Multi-agent orchestration' "$_reg_skills" 2>/dev/null; then
            _tmp="$_reg_skills.mhreg.$$"
            {
                printf '# Skills Catalog\n\n'
                printf 'This file is now user-maintained; the per-agent role is in [AGENTS.md](./AGENTS.md).\n\n'
                printf 'Add skill/category tables below as your roster grows. `memory-hive register` will\n'
                printf 'not touch this file once you have customized it.\n'
            } > "$_tmp" 2>/dev/null \
                && mv "$_tmp" "$_reg_skills" 2>/dev/null \
                || rm -f "$_tmp"
        fi
    fi

    return 0
}

# mh_citations: walk every silo and build a directed citation graph
# (citer -> cited). Renders the result into hive/registry/CITATIONS.md
# inside an auto-generated managed block, and prints a summary to stdout.
#
# Citation forms recognized:
#   1. Backtick-quoted agent name that matches another existing silo,
#      e.g.  `coder`, `security-auditor`. Matches must be whole-word
#      and must collide with a real silo to avoid false positives —
#      stray backticked words like `git` or `awk` are ignored unless
#      a `git` or `awk` silo actually exists.
#   2. Relative markdown link crossing a silo boundary, e.g.
#      [see X](../coder/log.md). Only counted when the path segment
#      after `../` is another agent's silo name.
#   3. Frontmatter `cites:` field at the top of a file —
#      `cites: [coder, reviewer]` or `cites: coder, reviewer`. Forward-
#      compatible: lets agents declare citations explicitly even when
#      the prose form misses them.
#
# Output:
#   - stdout: human-readable summary
#   - hive/registry/CITATIONS.md: rewrites the auto-block (preserves
#     anything outside the markers).
#
# Best-effort: returns 0 on a missing hive so callers can fire-and-forget.
mh_citations() {
    [ -d "$HIVE_DIR" ] || return 0
    [ -d "$AGENTS_DIR" ] || return 0

    _reg_dir="$HIVE_DIR/registry"
    mkdir -p "$_reg_dir" 2>/dev/null || return 0
    _reg_cit="$_reg_dir/CITATIONS.md"

    _start_marker="<!-- memory-hive:citations:start -->"
    _end_marker="<!-- memory-hive:citations:end -->"

    # Build the silo allow-list (one name per line). A citation is only
    # counted when both citer AND cited resolve to a real silo, which
    # kills the "stray backticked English word" false-positive.
    _silos_file="$_reg_dir/.cit-silos.$$"
    _mh_list_silos | sort -u > "$_silos_file" 2>/dev/null || {
        rm -f "$_silos_file"
        return 0
    }
    if [ ! -s "$_silos_file" ]; then
        rm -f "$_silos_file"
        return 0
    fi

    # Walk every silo's relevant files and emit "<citer>\t<cited>\t<date>"
    # records into a pairs file.
    _pairs_file="$_reg_dir/.cit-pairs.$$"
    : > "$_pairs_file"

    while IFS= read -r _citer; do
        [ -n "$_citer" ] || continue
        _silo_dir="$AGENTS_DIR/$_citer"
        [ -d "$_silo_dir" ] || continue

        # Standard triplet + any .md under learnings/.
        find "$_silo_dir" -type f \
            \( -name 'log.md' -o -name 'context.md' -o -name 'memory.md' \
               -o -path "$_silo_dir/learnings/*.md" \) \
            2>/dev/null | while IFS= read -r _f; do
            [ -f "$_f" ] || continue
            _mt="$(_mh_mtime_epoch "$_f" 2>/dev/null)"
            if [ -n "$_mt" ]; then
                _fdate="$(_mh_fmt_date "$_mt")"
            else
                _fdate="????-??-??"
            fi

            awk -v citer="$_citer" -v silosfile="$_silos_file" -v fdate="$_fdate" '
                BEGIN {
                    while ((getline _s < silosfile) > 0) {
                        if (_s != "") known[_s] = 1
                    }
                    close(silosfile)
                    in_fm = 0
                }
                # YAML frontmatter: must start on line 1.
                NR == 1 && /^---[[:space:]]*$/ { in_fm = 1; next }
                in_fm == 1 && /^---[[:space:]]*$/ { in_fm = 0; next }
                in_fm == 1 {
                    if (match($0, /^[[:space:]]*cites[[:space:]]*:[[:space:]]*/)) {
                        rest = substr($0, RSTART + RLENGTH)
                        gsub(/[\[\]"]/, "", rest)
                        n = split(rest, parts, /,/)
                        for (i = 1; i <= n; i++) {
                            cited = parts[i]
                            gsub(/^[[:space:]]+|[[:space:]]+$/, "", cited)
                            if (cited != "" && cited != citer && (cited in known)) {
                                printf "%s\t%s\t%s\n", citer, cited, fdate
                            }
                        }
                    }
                    next
                }

                # Backticked agent names: scan each line for `<token>`
                # whose token matches a real silo. Skip if the chars
                # immediately outside the backticks are also backticks
                # (i.e. inside a `` or ``` run).
                {
                    line = $0
                    while (match(line, /`[a-z0-9][a-z0-9-]*`/)) {
                        tok = substr(line, RSTART + 1, RLENGTH - 2)
                        before_pos = RSTART - 1
                        after_pos = RSTART + RLENGTH
                        before_ch = (before_pos >= 1) ? substr(line, before_pos, 1) : ""
                        after_ch = (after_pos <= length(line)) ? substr(line, after_pos, 1) : ""
                        if (before_ch != "`" && after_ch != "`") {
                            if (tok != citer && (tok in known)) {
                                printf "%s\t%s\t%s\n", citer, tok, fdate
                            }
                        }
                        line = substr(line, RSTART + RLENGTH)
                    }
                }

                # Relative markdown links: ](../<agent>/...).
                {
                    line2 = $0
                    while (match(line2, /\]\([^)]*\)/)) {
                        # Save outer offsets BEFORE running the inner match.
                        # awks match() clobbers RSTART/RLENGTH globally.
                        outer_start = RSTART
                        outer_len = RLENGTH
                        link = substr(line2, outer_start + 2, outer_len - 3)
                        if (match(link, /\.\.\/[a-z0-9][a-z0-9-]*\//)) {
                            seg = substr(link, RSTART + 3, RLENGTH - 4)
                            if (seg != citer && (seg in known)) {
                                printf "%s\t%s\t%s\n", citer, seg, fdate
                            }
                        }
                        line2 = substr(line2, outer_start + outer_len)
                    }
                }
            ' "$_f" >> "$_pairs_file"
        done
    done < "$_silos_file"

    # Aggregate pairs: count per (citer, cited) and keep max date.
    _agg_file="$_reg_dir/.cit-agg.$$"
    if [ -s "$_pairs_file" ]; then
        awk -F'\t' '
            {
                key = $1 "\t" $2
                count[key]++
                if (!(key in maxdate) || $3 > maxdate[key]) maxdate[key] = $3
            }
            END {
                for (k in count) {
                    printf "%s\t%d\t%s\n", k, count[k], maxdate[k]
                }
            }
        ' "$_pairs_file" | sort -t"$(printf '\t')" -k3,3nr -k1,1 -k2,2 > "$_agg_file"
    else
        : > "$_agg_file"
    fi

    # Per-agent totals.
    _out_file="$_reg_dir/.cit-out.$$"
    _in_file="$_reg_dir/.cit-in.$$"
    if [ -s "$_agg_file" ]; then
        awk -F'\t' '{ out[$1] += $3 } END { for (a in out) printf "%s\t%d\n", a, out[a] }' \
            "$_agg_file" | sort -t"$(printf '\t')" -k2,2nr -k1,1 > "$_out_file"
        awk -F'\t' '{ in_[$2] += $3 } END { for (a in in_) printf "%s\t%d\n", a, in_[a] }' \
            "$_agg_file" | sort -t"$(printf '\t')" -k2,2nr -k1,1 > "$_in_file"
    else
        : > "$_out_file"
        : > "$_in_file"
    fi

    _total=0
    if [ -s "$_agg_file" ]; then
        _total="$(awk -F'\t' '{ s += $3 } END { print s+0 }' "$_agg_file")"
    fi
    _agents_involved=0
    if [ -s "$_out_file" ] || [ -s "$_in_file" ]; then
        _agents_involved="$( { cut -f1 "$_out_file"; cut -f1 "$_in_file"; } | sort -u | wc -l | tr -d ' ')"
    fi
    _most_cited="-"
    _most_cited_n=0
    if [ -s "$_in_file" ]; then
        _most_cited="$(head -n 1 "$_in_file" | cut -f1)"
        _most_cited_n="$(head -n 1 "$_in_file" | cut -f2)"
    fi
    _most_citing="-"
    _most_citing_n=0
    if [ -s "$_out_file" ]; then
        _most_citing="$(head -n 1 "$_out_file" | cut -f1)"
        _most_citing_n="$(head -n 1 "$_out_file" | cut -f2)"
    fi

    # Build the auto-block.
    _blk="$_reg_dir/.cit-blk.$$"
    {
        printf '%s\n' "$_start_marker"
        printf '<!-- Auto-generated by `memory-hive citations`. Do not edit by hand. -->\n'
        printf '\n'
        printf '## Cross-agent citations\n\n'
        if [ -s "$_agg_file" ]; then
            printf '| Citer | Cited | Count | Most recent |\n'
            printf '|---|---|---|---|\n'
            sort -t"$(printf '\t')" -k3,3nr -k1,1 -k2,2 "$_agg_file" \
                | while IFS="$(printf '\t')" read -r _ci _cd _ct _dt; do
                    printf '| %s | %s | %s | %s |\n' "$_ci" "$_cd" "$_ct" "$_dt"
                done
        else
            printf '_No cross-agent citations detected yet._\n'
        fi
        printf '\n'
        printf '## Summary\n\n'
        printf -- '- %s total citations across %s agents\n' "$_total" "$_agents_involved"
        if [ "$_most_cited" != "-" ]; then
            printf -- '- Most-cited: %s (%s incoming)\n' "$_most_cited" "$_most_cited_n"
        fi
        if [ "$_most_citing" != "-" ]; then
            printf -- '- Most-citing: %s (%s outgoing)\n' "$_most_citing" "$_most_citing_n"
        fi
        printf '\n'
        printf '%s\n' "$_end_marker"
    } > "$_blk" 2>/dev/null || {
        rm -f "$_blk" "$_silos_file" "$_pairs_file" "$_agg_file" "$_out_file" "$_in_file"
        return 0
    }

    # Splice into CITATIONS.md, preserving everything outside the markers.
    if [ -f "$_reg_cit" ] \
        && grep -q -F "$_start_marker" "$_reg_cit" 2>/dev/null \
        && grep -q -F "$_end_marker" "$_reg_cit" 2>/dev/null; then
        _tmp="$_reg_cit.mhcit.$$"
        awk -v start="$_start_marker" -v end="$_end_marker" -v blockfile="$_blk" '
            BEGIN { inblock = 0 }
            {
                if (inblock == 0 && index($0, start) > 0) {
                    while ((getline line < blockfile) > 0) print line
                    close(blockfile)
                    inblock = 1
                    next
                }
                if (inblock == 1) {
                    if (index($0, end) > 0) { inblock = 0 }
                    next
                }
                print
            }
        ' "$_reg_cit" > "$_tmp" 2>/dev/null \
            && mv "$_tmp" "$_reg_cit" 2>/dev/null \
            || rm -f "$_tmp"
    else
        if [ ! -f "$_reg_cit" ]; then
            {
                printf '# Citation Graph\n\n'
                printf 'Cross-agent citations across the hive. The block below is\n'
                printf 'auto-generated from silo `log.md`, `context.md`, `memory.md`,\n'
                printf 'and `learnings/*.md` files by `memory-hive citations`. Edit\n'
                printf 'silo content, not this file.\n\n'
                printf 'Citation forms recognized:\n'
                printf -- '- Backtick-quoted agent name (`coder`, `reviewer`)\n'
                printf -- '- Relative markdown link crossing a silo (`[see X](../coder/log.md)`)\n'
                printf -- '- Frontmatter `cites:` list (forward-compatible)\n\n'
                cat "$_blk"
                printf '\n'
            } > "$_reg_cit" 2>/dev/null || rm -f "$_reg_cit"
        else
            _tmp="$_reg_cit.mhcit.$$"
            {
                cat "$_reg_cit"
                _last="$(tail -c 1 "$_reg_cit" 2>/dev/null || printf '')"
                if [ "$_last" != "" ] && [ "$_last" != "
" ]; then
                    printf '\n'
                fi
                printf '\n'
                cat "$_blk"
                printf '\n'
            } > "$_tmp" 2>/dev/null \
                && mv "$_tmp" "$_reg_cit" 2>/dev/null \
                || rm -f "$_tmp"
        fi
    fi

    # Stdout summary.
    printf 'Memory Hive — citations\n'
    printf 'Hive: %s\n\n' "$HIVE_DIR"
    if [ "$_total" -eq 0 ]; then
        printf 'No cross-agent citations detected yet.\n'
        printf '(Looked in: log.md, context.md, memory.md, learnings/*.md across %s silos.)\n' \
            "$(wc -l < "$_silos_file" | tr -d ' ')"
    else
        printf 'Total citations: %s across %s agents\n' "$_total" "$_agents_involved"
        if [ "$_most_cited" != "-" ]; then
            printf 'Most-cited:     %s (%s incoming)\n' "$_most_cited" "$_most_cited_n"
        fi
        if [ "$_most_citing" != "-" ]; then
            printf 'Most-citing:    %s (%s outgoing)\n' "$_most_citing" "$_most_citing_n"
        fi
        printf '\nTop edges:\n'
        head -n 10 "$_agg_file" | while IFS="$(printf '\t')" read -r _ci _cd _ct _dt; do
            printf '  %-20s -> %-20s  %s  (last: %s)\n' "$_ci" "$_cd" "$_ct" "$_dt"
        done
    fi
    printf '\nWrote: %s\n' "$_reg_cit"

    # Cleanup.
    rm -f "$_silos_file" "$_pairs_file" "$_agg_file" "$_out_file" "$_in_file" "$_blk"
    return 0
}

# _mh_register_quiet: swallow all output, never fail the caller. Used by the
# other verbs as a best-effort hook. Also rebuilds the citation graph so
# AGENTS.md and CITATIONS.md stay in sync from the same trigger.
_mh_register_quiet() {
    mh_register >/dev/null 2>&1 || true
    mh_citations >/dev/null 2>&1 || true
}

# mh_doctor: health-check the install. Prints findings and exits 0 if clean,
# 1 if anything fired a warning.
mh_doctor() {
    # Colors mirror install.sh's style so the whole toolchain looks uniform.
    if [ -t 1 ]; then
        _D_BOLD="$(printf '\033[1m')"
        _D_GREEN="$(printf '\033[32m')"
        _D_YELLOW="$(printf '\033[33m')"
        _D_RED="$(printf '\033[31m')"
        _D_CYAN="$(printf '\033[36m')"
        _D_RESET="$(printf '\033[0m')"
    else
        _D_BOLD=""; _D_GREEN=""; _D_YELLOW=""; _D_RED=""; _D_CYAN=""; _D_RESET=""
    fi
    _D_OK="${_D_GREEN}OK${_D_RESET}"
    _D_WARN="${_D_YELLOW}!!${_D_RESET}"
    _D_ERR="${_D_RED}ERROR${_D_RESET}"

    _warnings=0

    printf '%sMemory Hive doctor%s\n' "$_D_BOLD" "$_D_RESET"
    printf 'Install dir: %s\n' "$INSTALL_DIR"
    printf '\n'

    # --- 1. hive/ exists ---------------------------------------------------
    if [ -d "$HIVE_DIR" ]; then
        printf '  %s hive/ directory present\n' "$_D_OK"
    else
        printf '  %s hive/ directory missing at %s\n' "$_D_ERR" "$HIVE_DIR"
        printf '     run `sh %s/install.sh` to recreate.\n' "$INSTALL_DIR"
        return 1
    fi

    # --- 2. main silo triplet ----------------------------------------------
    _main_dir="$AGENTS_DIR/main"
    _main_missing=""
    for _f in log.md context.md memory.md; do
        [ -f "$_main_dir/$_f" ] || _main_missing="$_main_missing $_f"
    done
    if [ ! -d "$_main_dir" ]; then
        printf '  %s main silo missing at %s\n' "$_D_WARN" "$_main_dir"
        _warnings=$((_warnings + 1))
    elif [ -n "$_main_missing" ]; then
        printf '  %s main silo incomplete — missing:%s\n' "$_D_WARN" "$_main_missing"
        _warnings=$((_warnings + 1))
    else
        printf '  %s main silo has log.md, context.md, memory.md\n' "$_D_OK"
    fi

    # --- 3. other silo triplets --------------------------------------------
    _silo_issues=0
    _silo_count=0
    for _p in "$AGENTS_DIR"/*; do
        [ -d "$_p" ] || continue
        _n="$(basename "$_p")"
        case "$_n" in
            _archived|.*|main) continue ;;
        esac
        _silo_count=$((_silo_count + 1))
        _missing=""
        for _f in log.md context.md memory.md; do
            [ -f "$_p/$_f" ] || _missing="$_missing $_f"
        done
        if [ -n "$_missing" ]; then
            printf '  %s silo %s incomplete — missing:%s\n' "$_D_WARN" "$_n" "$_missing"
            _silo_issues=$((_silo_issues + 1))
            _warnings=$((_warnings + 1))
        fi
    done
    if [ "$_silo_count" -gt 0 ] && [ "$_silo_issues" -eq 0 ]; then
        printf '  %s %s non-archived silo(s) have the full triplet\n' "$_D_OK" "$_silo_count"
    elif [ "$_silo_count" -eq 0 ]; then
        printf '  %s no non-main silos yet (add with `memory-hive add <name>`)\n' "$_D_OK"
    fi

    # --- 4. Managed-block health for every supported platform --------------
    # For each platform whose config file exists on this machine, verify
    # the managed block is present and points at $INSTALL_DIR. Platforms
    # with a `manual` strategy aren't checked here (the user wired them by
    # hand; we can't verify what we don't own).
    #
    # Stdout-only pipeline: we want to both print status lines AND count
    # warnings. POSIX pipelines run in subshells, so we accumulate findings
    # in a temp file and read totals back after the loop.
    _start="<!-- memory-hive:start -->"
    _end="<!-- memory-hive:end -->"

    # (id, display-name, relative-path) per auto-injected platform. Keep
    # in sync with install.sh's platform table.
    _plat_table="$INSTALL_DIR/.doctor-plats.$$"
    cat > "$_plat_table" <<'PLATS'
claude-code	Claude Code	.claude/CLAUDE.md
openclaw	OpenClaw	.openclaw/CLAUDE.md
nanoclaw	NanoClaw	.config/nanoclaw/AGENTS.md
hermes	Hermes Agent	.hermes/memories/MEMORY.md
cursor	Cursor	.cursor/rules/memory-hive.mdc
continue	Continue.dev	.continue/rules/memory-hive.md
gemini-cli	Gemini CLI	.gemini/GEMINI.md
goose	Goose	.goosehints
amazon-q	Amazon Q	.aws/amazonq/rules/memory-hive.md
openhands	OpenHands	.openhands/microagents/memory-hive.md
roo-code	Roo Code	.roo/rules/memory-hive.md
kilo-code	Kilo Code	.kilocode/rules/memory-hive.md
windsurf	Windsurf	.codeium/windsurf/memories/global_rules.md
warp	Warp	.agents/AGENTS.md
amp	Sourcegraph Amp	.config/amp/AGENTS.md
codex	Codex CLI	.codex/AGENTS.md
opencode	OpenCode	.config/opencode/AGENTS.md
PLATS

    _plat_seen=0
    _plat_warnings=0
    while IFS='	' read -r _pid _pname _prel; do
        [ -n "$_pid" ] || continue
        _target="$HOME/$_prel"
        [ -f "$_target" ] || continue
        _plat_seen=$((_plat_seen + 1))
        if grep -q -F "$_start" "$_target" 2>/dev/null \
            && grep -q -F "$_end" "$_target" 2>/dev/null; then
            _block="$(awk -v s="$_start" -v e="$_end" '
                BEGIN { inb = 0 }
                { if (index($0, s) > 0) { inb = 1; next } }
                inb == 1 { if (index($0, e) > 0) { inb = 0; next }; print }
            ' "$_target")"
            if printf '%s' "$_block" | grep -q -F "$INSTALL_DIR" 2>/dev/null; then
                printf '  %s %s block points at this install (~/%s)\n' \
                    "$_D_OK" "$_pname" "$_prel"
            else
                printf '  %s %s block does not reference %s\n' \
                    "$_D_WARN" "$_pname" "$INSTALL_DIR"
                printf '     run `sh %s/install.sh` to refresh.\n' "$INSTALL_DIR"
                _plat_warnings=$((_plat_warnings + 1))
            fi
        else
            printf '  %s %s config exists but has no memory-hive block (~/%s)\n' \
                "$_D_WARN" "$_pname" "$_prel"
            printf '     run `sh %s/install.sh` to add it.\n' "$INSTALL_DIR"
            _plat_warnings=$((_plat_warnings + 1))
        fi
    done < "$_plat_table"
    rm -f "$_plat_table"

    if [ "$_plat_seen" -eq 0 ]; then
        printf '  %s no agent-platform config files detected (skipping block check)\n' "$_D_OK"
    fi
    _warnings=$((_warnings + _plat_warnings))

    # --- 5. registry AGENTS.md is in sync ----------------------------------
    _reg="$HIVE_DIR/registry/AGENTS.md"
    if [ ! -f "$_reg" ]; then
        printf '  %s registry AGENTS.md missing — run `memory-hive register`\n' "$_D_WARN"
        _warnings=$((_warnings + 1))
    else
        _start_m="<!-- memory-hive:agents:start -->"
        _end_m="<!-- memory-hive:agents:end -->"
        if ! grep -q -F "$_start_m" "$_reg" 2>/dev/null \
            || ! grep -q -F "$_end_m" "$_reg" 2>/dev/null; then
            printf '  %s registry AGENTS.md has no auto-generated block — run `memory-hive register`\n' "$_D_WARN"
            _warnings=$((_warnings + 1))
        else
            # Extract agent names from the table body (rows between the markers
            # that look like `| <name> | ...`).
            _reg_names="$(awk -v s="$_start_m" -v e="$_end_m" '
                BEGIN { inb = 0 }
                { if (index($0, s) > 0) { inb = 1; next } }
                inb == 1 {
                    if (index($0, e) > 0) { inb = 0; next }
                    if ($0 ~ /^\| [^|]* \| /) {
                        n = $0
                        sub(/^\| /, "", n)
                        sub(/ \|.*/, "", n)
                        if (n != "Agent" && n != "---") print n
                    }
                }
            ' "$_reg" | sort -u)"
            _disk_names="$(_mh_list_silos | sort -u)"
            if [ "$_reg_names" = "$_disk_names" ]; then
                printf '  %s registry AGENTS.md matches on-disk silos\n' "$_D_OK"
            else
                printf '  %s registry AGENTS.md is out of sync — run `memory-hive register`\n' "$_D_WARN"
                _warnings=$((_warnings + 1))
            fi
        fi
    fi

    # --- 6. archived silo count (informational only) -----------------------
    _arch_count=0
    _arch_root="$AGENTS_DIR/_archived"
    if [ -d "$_arch_root" ]; then
        for _ad in "$_arch_root"/*; do
            [ -d "$_ad" ] || continue
            for _as in "$_ad"/*; do
                [ -d "$_as" ] || continue
                _arch_count=$((_arch_count + 1))
            done
        done
    fi
    if [ "$_arch_count" -gt 0 ]; then
        printf '  %s archived silos: %s (informational)\n' "${_D_CYAN}i${_D_RESET}" "$_arch_count"
    fi

    printf '\n'
    if [ "$_warnings" -eq 0 ]; then
        printf '%sDoctor:%s clean.\n' "$_D_BOLD" "$_D_RESET"
        return 0
    else
        printf '%sDoctor:%s %s warning(s). See above.\n' "$_D_BOLD" "$_D_RESET" "$_warnings"
        return 1
    fi
}

# --- verbs -------------------------------------------------------------------

mh_help() {
    cat <<EOF
memory-hive — manage agent silos in your hive.

Usage:
  memory-hive add <name> [--role <template|path>]
      Create a new agent silo. <name> is sanitized to lowercase
      letters/digits/dashes. <template> is one of: $(_mh_list_templates).
      Alternatively pass a path to a .md file for a custom role.

  memory-hive list
      Print the current roster (excluding archived).

  memory-hive archive <name>
      Move the silo to hive/agents/_archived/<YYYY-MM-DD>/<name>/.
      Never deletes.

  memory-hive role <name>
      Open the agent's context.md in \$EDITOR (defaults to vi).

  memory-hive rename <old> <new>
      Rename a silo directory. <old> must exist, <new> must not.

  memory-hive register
      Regenerate hive/registry/AGENTS.md from the current silo contents.
      Runs automatically after add/archive/rename/role, so most users will
      never call it directly. Also rebuilds CITATIONS.md.

  memory-hive citations
      Scan every silo for cross-agent citations (backticked agent names,
      relative markdown links, and frontmatter \`cites:\` lists) and
      rewrite hive/registry/CITATIONS.md as a directed graph showing
      who cites whom. Also fires from \`register\`.

  memory-hive doctor
      Health-check the install: verifies hive layout, silo triplets, the
      managed CLAUDE.md block, and that AGENTS.md matches on-disk silos.

  memory-hive setup
      Run the interactive setup wizard — asks how many agents you want,
      their names, and roles. Also offers to import agents from
      ~/.claude/agents/ and ~/.openclaw/hive/agents/ if either exists.

  memory-hive apply
      Find running agent processes and print the exact commands to
      restart them so the managed block takes effect. Non-destructive
      by default (prints advice, doesn't kill anything). Add --force
      to SIGTERM detected CLI agents.

  memory-hive stats
      Honest telemetry. Counts REAL file writes in the hive (silo
      logs, memory bullets, raw learnings, curator promotions) by
      agent and by time window. Every count maps to a file on disk
      you can `ls -la` yourself. No timers, no proxies, no fake
      activity.

  memory-hive watch
      Live stream of file events as agents write to the hive. Prints
      timestamp + agent + file for each event and keeps a running
      counter. Ctrl+C to exit. Uses fswatch or inotifywait if
      available; falls back to polling (5s).

  memory-hive help
      Show this message.

Install root: $INSTALL_DIR
EOF
}

# mh_apply — detect running agent processes and tell the user how to
# restart them so the installer's managed block takes effect. Pure
# diagnostic by default; --force sends SIGTERM to CLI agents (not
# desktop apps — a shell installer has no business killing those).
mh_apply() {
    _force=0
    _yes=0
    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--force) _force=1 ;;
            -y|--yes)   _yes=1 ;;
            -h|--help)
                printf 'Usage: memory-hive apply [--force] [--yes]\n'
                printf '  Without --force: prints what to restart.\n'
                printf '  With --force:    SIGTERMs detected CLI agents (asks first unless --yes).\n'
                return 0
                ;;
            *) printf 'Unknown flag: %s\n' "$1" >&2; return 2 ;;
        esac
        shift
    done

    # Process name patterns we understand. Exact-match on basename so
    # we don't sweep up unrelated binaries. Keep this list conservative
    # — it's safer to miss a niche agent than to kill an unrelated
    # process that happens to match.
    _patterns='aider goose claude codex opencode crush'

    _found=""
    for _pat in $_patterns; do
        # pgrep -x = exact command-name match. Portable across macOS
        # and Linux; fails silently if pgrep isn't on PATH.
        _pids="$(pgrep -x "$_pat" 2>/dev/null || true)"
        [ -n "$_pids" ] || continue
        for _pid in $_pids; do
            # Skip our own shell + any parent in the tree.
            [ "$_pid" = "$$" ] && continue
            if [ -z "$_found" ]; then
                _found="$_pat:$_pid"
            else
                _found="$_found $_pat:$_pid"
            fi
        done
    done

    # Also note desktop apps — we won't touch them, but users need to
    # know a restart is required. Detection is best-effort: pgrep -f
    # against well-known app bundle names (macOS-ish). Doesn't populate
    # on Linux if the app binary has a different name; that's fine.
    _desktop=""
    for _app in "Claude" "Cursor" "Windsurf" "Zed" "Warp"; do
        if pgrep -x "$_app" >/dev/null 2>&1; then
            if [ -z "$_desktop" ]; then _desktop="$_app"; else _desktop="$_desktop $_app"; fi
        fi
    done

    if [ -z "$_found" ] && [ -z "$_desktop" ]; then
        printf 'No running agent processes detected. Nothing to apply.\n'
        printf 'Changes take effect the next time you start an agent.\n'
        return 0
    fi

    printf 'Agents detected:\n'
    if [ -n "$_found" ]; then
        for _entry in $_found; do
            _name="${_entry%%:*}"
            _pid="${_entry##*:}"
            printf '  CLI     %-10s pid=%s\n' "$_name" "$_pid"
        done
    fi
    if [ -n "$_desktop" ]; then
        for _app in $_desktop; do
            printf '  Desktop %-10s (quit + reopen to apply)\n' "$_app"
        done
    fi

    if [ "$_force" -ne 1 ]; then
        printf '\nTo restart the CLI agents, run:\n'
        if [ -n "$_found" ]; then
            for _entry in $_found; do
                _name="${_entry%%:*}"
                _pid="${_entry##*:}"
                printf '  kill %s  # %s — then re-run `%s` in your terminal\n' "$_pid" "$_name" "$_name"
            done
        fi
        if [ -n "$_desktop" ]; then
            printf '\nDesktop apps need a manual quit + reopen:\n'
            for _app in $_desktop; do
                printf '  - Quit and reopen %s\n' "$_app"
            done
        fi
        printf '\nRe-run with `memory-hive apply --force` to send SIGTERM to the CLI agents.\n'
        return 0
    fi

    # --force path: confirm unless --yes
    if [ "$_yes" -ne 1 ]; then
        printf '\n--force will SIGTERM every CLI agent listed above. Desktop apps are\n'
        printf 'never touched. Proceed? [y/N]: '
        _ans=""
        IFS= read -r _ans || return 1
        case "$_ans" in
            y|Y|yes|YES|Yes) ;;
            *) printf 'Aborted.\n'; return 0 ;;
        esac
    fi

    _killed=0
    _failed=0
    for _entry in $_found; do
        _name="${_entry%%:*}"
        _pid="${_entry##*:}"
        if kill "$_pid" 2>/dev/null; then
            printf '  SIGTERM %s (%s)\n' "$_pid" "$_name"
            _killed=$((_killed + 1))
        else
            printf '  FAILED  %s (%s) — permission or process gone\n' "$_pid" "$_name" >&2
            _failed=$((_failed + 1))
        fi
    done

    printf '\nDone. %d terminated, %d failed.\n' "$_killed" "$_failed"
    if [ -n "$_desktop" ]; then
        printf 'Desktop apps still need a manual quit + reopen: %s\n' "$_desktop"
    fi
    return 0
}

# --- telemetry: stats + watch ------------------------------------------------
#
# Every signal here comes from a real file write under $HIVE_DIR. We never
# count time-based "activations"; we count files whose mtime is newer than
# the window. That means:
#   - if no agent writes to its silo, the counter stays at zero
#   - if an agent claims to have written but didn't, the counter stays at zero
#   - counts always match what `ls -la` + `find -mtime` will show
# This is the anti-trick property the user asked for.

# _mh_classify <abspath> → prints `agent:kind` to stdout, or empty to skip.
# Maps a hive file path to (who did it, what kind of write it was).
_mh_classify() {
    _p="$1"
    # Normalize: strip HIVE_DIR prefix so we operate on relative paths.
    case "$_p" in
        "$HIVE_DIR"/*) _rel="${_p#"$HIVE_DIR"/}" ;;
        *) return 0 ;;
    esac
    case "$_rel" in
        agents/_archived/*)              return 0 ;;  # archived — don't count
        agents/*/log.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf '%s:log' "$_who" ;;
        agents/*/memory.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf '%s:memory' "$_who" ;;
        agents/*/context.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf '%s:context' "$_who" ;;
        agents/*/learnings/*.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf '%s:learning' "$_who" ;;
        learnings/raw/*/*.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $3}')"
            printf '%s:raw' "$_who" ;;
        learnings/raw/*.md)
            printf 'unknown:raw' ;;
        learnings/distilled/*.md)
            printf 'curator:distilled' ;;
        curator/DECISIONS.md)            printf 'curator:decision' ;;
        curator/CONFLICTS.md)            printf 'curator:conflict' ;;
        curator/DRAFT.md)                printf 'curator:draft' ;;
        knowledge/*.md)                  printf 'curator:knowledge' ;;
        raw/*/*.md)                      # Tier 1 external ingestion
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf 'ingester:%s' "$_who" ;;
        *) return 0 ;;
    esac
}

# _mh_hive_file_list — print one path per line for every file under $HIVE_DIR
# that counts as a hive write (skips .git, .upstream, .local backups, dirs).
_mh_hive_file_list() {
    [ -d "$HIVE_DIR" ] || return 0
    find "$HIVE_DIR" -type f \
        ! -name "*.upstream" \
        ! -name "*.local" \
        ! -name ".DS_Store" \
        ! -path "*/.git/*" \
        2>/dev/null
}

# _mh_mtime_epoch <path> → seconds since epoch (portable macOS + GNU).
_mh_mtime_epoch() {
    # GNU stat first (Linux), then BSD stat (macOS).
    stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null
}

# _mh_fmt_time <epoch> → "HH:MM:SS" in local time.
_mh_fmt_time() {
    _e="$1"
    # GNU date accepts @epoch, BSD date accepts -r epoch. Try both.
    date -d "@$_e" '+%H:%M:%S' 2>/dev/null || date -r "$_e" '+%H:%M:%S' 2>/dev/null || printf '??:??:??'
}

# _mh_fmt_date <epoch> → "YYYY-MM-DD".
_mh_fmt_date() {
    _e="$1"
    date -d "@$_e" '+%Y-%m-%d' 2>/dev/null || date -r "$_e" '+%Y-%m-%d' 2>/dev/null || printf '????-??-??'
}

mh_stats() {
    _mh_require_install

    _now="$(date +%s)"
    # Start-of-today in local time.
    _today0="$(date -d 'today 00:00:00' +%s 2>/dev/null || date -v0H -v0M -v0S +%s 2>/dev/null || printf '%s' "$_now")"
    _week_ago=$((_now - 7 * 86400))

    # Baseline: the installer touches $HIVE_DIR/.baseline-installed as its
    # last step. Files with mtime <= baseline are installer scaffolding, not
    # agent activity, and get excluded from the counter. Without this the
    # counter lies on a fresh install ("13 writes" from the templates).
    _baseline_file="$HIVE_DIR/.baseline-installed"
    _baseline_mtime=0
    _baseline_missing=0
    if [ -f "$_baseline_file" ]; then
        _baseline_mtime="$(_mh_mtime_epoch "$_baseline_file")"
        [ -n "$_baseline_mtime" ] || _baseline_mtime=0
    else
        _baseline_missing=1
    fi

    # Pipeline emits records; aggregation happens after to keep counters.
    _mh_hive_file_list | while IFS= read -r _f; do
        _cls="$(_mh_classify "$_f")"
        [ -n "$_cls" ] || continue
        _mt="$(_mh_mtime_epoch "$_f")"
        [ -n "$_mt" ] || continue
        # Drop installer scaffolding (files touched at or before baseline).
        if [ "$_baseline_mtime" -gt 0 ] && [ "$_mt" -le "$_baseline_mtime" ]; then
            continue
        fi
        printf '%s\t%s\t%s\n' "$_mt" "$_cls" "$_f"
    done | sort -nr > /tmp/mh-stats.$$

    _total=0; _today=0; _week=0
    _agent_tally=""
    _kind_tally=""
    _latest_row=""
    while IFS=$(printf '\t') read -r _mt _cls _f; do
        [ -n "$_mt" ] || continue
        _total=$((_total + 1))
        [ "$_mt" -ge "$_today0" ] && _today=$((_today + 1))
        [ "$_mt" -ge "$_week_ago" ] && _week=$((_week + 1))
        _who="${_cls%%:*}"
        _kind="${_cls##*:}"
        _agent_tally="$_agent_tally $_who"
        _kind_tally="$_kind_tally $_kind"
        [ -z "$_latest_row" ] && _latest_row="$_mt|$_cls|$_f"
    done < /tmp/mh-stats.$$
    rm -f /tmp/mh-stats.$$

    # --- render -------------------------------------------------------------
    printf '\nMemory Hive — activity\n'
    printf 'Hive: %s\n' "$HIVE_DIR"
    if [ "$_baseline_missing" -eq 1 ]; then
        printf '\n  (no .baseline-installed marker — re-run the installer to set it;\n'
        printf '   stats below include install-time scaffolding until then)\n'
    else
        printf 'Since install: %s\n' "$(_mh_fmt_date "$_baseline_mtime")"
    fi
    printf '\n'
    printf '  %-14s %s\n' "Today:"       "$_today writes"
    printf '  %-14s %s\n' "Last 7 days:" "$_week writes"
    printf '  %-14s %s\n' "All-time:"    "$_total writes"

    if [ "$_total" -eq 0 ]; then
        printf '\n  (no agent has written to the hive yet — run a task and come back)\n'
        printf '\n  Every count here corresponds to a file under %s\n' "$HIVE_DIR"
        printf '  whose mtime is newer than the install baseline.\n'
        printf '  Verify with: find %s -type f -newer %s\n\n' "$HIVE_DIR" "$_baseline_file"
        return 0
    fi

    printf '\nBy agent:\n'
    printf '%s\n' $_agent_tally | sort | uniq -c | sort -rn | while read _c _a; do
        printf '  %-24s %s\n' "$_a" "$_c"
    done

    printf '\nBy kind:\n'
    printf '%s\n' $_kind_tally | sort | uniq -c | sort -rn | while read _c _k; do
        printf '  %-24s %s\n' "$_k" "$_c"
    done

    if [ -n "$_latest_row" ]; then
        _mt="${_latest_row%%|*}"
        _rest="${_latest_row#*|}"
        _cls="${_rest%%|*}"
        _f="${_rest#*|}"
        _rel="${_f#"$HIVE_DIR"/}"
        printf '\nMost recent write: %s · %s · %s\n' "$(_mh_fmt_date "$_mt") $(_mh_fmt_time "$_mt")" "$_cls" "$_rel"
    fi

    # Honest-by-construction footer — tells users how to verify independently.
    printf '\nVerify: find %s -type f -newer %s\n\n' "$HIVE_DIR" "$_baseline_file"
}

# mh_watch — live stream. Uses the best available watcher.
mh_watch() {
    _mh_require_install
    [ -d "$HIVE_DIR" ] || _mh_die "Hive directory missing: $HIVE_DIR"

    printf 'Memory Hive — live activity  (Ctrl+C to exit)\n'
    printf 'Watching: %s\n' "$HIVE_DIR"
    printf '──────────────────────────────────────────────\n'

    _session_count=0

    # _handle_event <path> — classify, count, print. Called for each event.
    _handle_event() {
        _path="$1"
        [ -f "$_path" ] || return 0
        _cls="$(_mh_classify "$_path")"
        [ -n "$_cls" ] || return 0
        _mt="$(_mh_mtime_epoch "$_path")"
        [ -n "$_mt" ] || _mt="$(date +%s)"
        _session_count=$((_session_count + 1))
        _who="${_cls%%:*}"
        _kind="${_cls##*:}"
        _rel="${_path#"$HIVE_DIR"/}"
        printf '%s  [%03d]  %-18s %-10s %s\n' \
            "$(_mh_fmt_time "$_mt")" "$_session_count" "$_who" "$_kind" "$_rel"
    }

    if command -v fswatch >/dev/null 2>&1; then
        # macOS / portable — fswatch emits one path per line.
        fswatch -0 "$HIVE_DIR" 2>/dev/null | while IFS= read -r -d '' _path; do
            _handle_event "$_path"
        done
    elif command -v inotifywait >/dev/null 2>&1; then
        # Linux — inotifywait with -m keeps streaming.
        inotifywait -mrq -e close_write,create,modify --format '%w%f' "$HIVE_DIR" 2>/dev/null | while IFS= read -r _path; do
            _handle_event "$_path"
        done
    else
        # Polling fallback: scan every 5s for files modified since the last
        # scan. Uses a sentinel file for the time reference (portable vs.
        # `find -newermt "<date>"` which isn't POSIX).
        _sentinel="$(mktemp -t mh-watch.XXXXXX)"
        printf '(polling every 5s — install fswatch or inotify-tools for instant updates)\n'
        while :; do
            sleep 5
            _newer=""
            # -newer <file> is POSIX. Collect changed files into a list.
            _newer="$(find "$HIVE_DIR" -type f -newer "$_sentinel" 2>/dev/null \
                ! -name '*.upstream' ! -name '*.local' ! -name '.DS_Store' \
                ! -path '*/.git/*')"
            touch "$_sentinel"
            [ -z "$_newer" ] && continue
            printf '%s\n' "$_newer" | while IFS= read -r _path; do
                [ -n "$_path" ] && _handle_event "$_path"
            done
        done
    fi
}

mh_setup() {
    _mh_require_install
    _installer="$INSTALL_DIR/install.sh"
    if [ ! -f "$_installer" ]; then
        printf 'ERROR: installer not found at %s\n' "$_installer" >&2
        printf 'Re-run the install to restore it:\n' >&2
        printf '  curl -fsSL https://raw.githubusercontent.com/TJCurnutte/memory-hive/main/install.sh | sh\n' >&2
        return 1
    fi
    MEMORY_HIVE_WIZARD=1 MEMORY_HIVE_DIR="$INSTALL_DIR" \
        MEMORY_HIVE_SKIP_CLAUDE_MD="${MEMORY_HIVE_SKIP_CLAUDE_MD:-1}" \
        sh "$_installer"
}

mh_list() {
    _mh_require_install
    if [ ! -d "$AGENTS_DIR" ]; then
        printf '(no agents yet)\n'
        return 0
    fi
    _found=0
    for _p in "$AGENTS_DIR"/*; do
        [ -d "$_p" ] || continue
        _n="$(basename "$_p")"
        case "$_n" in
            _archived|.*) continue ;;
        esac
        _found=1
        # Try to pull the first non-placeholder line from ## Role in context.md.
        _role_summary=""
        _cfile="$_p/context.md"
        if [ -f "$_cfile" ]; then
            _role_summary="$(awk '
                /^## Role$/ { inrole = 1; next }
                inrole == 1 && /^## / { exit }
                inrole == 1 {
                    # Skip blank lines and placeholder parenthetical prompts.
                    if ($0 ~ /^[[:space:]]*$/) next
                    if ($0 ~ /^\([^)]*\)$/) next
                    print
                    exit
                }
            ' "$_cfile")"
        fi
        if [ -n "$_role_summary" ]; then
            # Trim to ~70 chars for one-line display.
            _role_summary="$(printf '%s' "$_role_summary" | cut -c1-70)"
            printf '  %-20s %s\n' "$_n" "$_role_summary"
        else
            printf '  %-20s (no role set)\n' "$_n"
        fi
    done
    if [ "$_found" -eq 0 ]; then
        printf '(no agents yet)\n'
    fi
}

mh_add() {
    _mh_require_install
    _name_raw="$1"
    shift || true
    if [ -z "$_name_raw" ]; then
        _mh_die "Usage: memory-hive add <name> [--role <template|path>]"
    fi
    _role_arg=""
    # Parse remaining args. Only --role is supported for now.
    while [ $# -gt 0 ]; do
        case "$1" in
            --role)
                shift
                if [ $# -eq 0 ]; then
                    _mh_die "--role needs a value (template name or path)"
                fi
                _role_arg="$1"
                shift
                ;;
            --role=*)
                _role_arg="${1#--role=}"
                shift
                ;;
            *)
                _mh_die "Unknown argument: $1"
                ;;
        esac
    done

    _name="$(_mh_sanitize_name "$_name_raw")"
    if [ -z "$_name" ]; then
        _mh_die "Name must contain letters or digits (lowercase, dashes allowed)."
    fi
    if [ "$_name" = "main" ] || [ "$_name" = "_archived" ]; then
        _mh_die "'$_name' is a reserved name."
    fi
    if [ -d "$AGENTS_DIR/$_name" ]; then
        _mh_die "Agent '$_name' already exists at $AGENTS_DIR/$_name"
    fi

    _role_text=""
    if [ -n "$_role_arg" ]; then
        _role_text="$(_mh_resolve_role "$_role_arg")"
    fi

    if [ ! -f "$CREATE_AGENT" ]; then
        _mh_die "create-agent.sh missing at $CREATE_AGENT — reinstall Memory Hive."
    fi

    if [ -n "$_role_text" ]; then
        MH_AGENT_ROLE="$_role_text" \
            MEMORY_HIVE_DIR="$INSTALL_DIR" \
            sh "$CREATE_AGENT" "$_name"
    else
        MEMORY_HIVE_DIR="$INSTALL_DIR" \
            sh "$CREATE_AGENT" "$_name"
    fi
    _mh_register_quiet
}

mh_archive() {
    _mh_require_install
    _name="$1"
    [ -z "$_name" ] && _mh_die "Usage: memory-hive archive <name>"
    case "$_name" in
        main|_archived) _mh_die "'$_name' cannot be archived." ;;
    esac
    _src="$AGENTS_DIR/$_name"
    if [ ! -d "$_src" ]; then
        _mh_die "No such agent: $_name (looked in $_src)"
    fi
    _date="$(date -u +%Y-%m-%d 2>/dev/null || echo "today")"
    _arch_root="$AGENTS_DIR/_archived/$_date"
    mkdir -p "$_arch_root" || _mh_die "Could not create $_arch_root"
    _dst="$_arch_root/$_name"
    if [ -e "$_dst" ]; then
        _i=1
        while [ -e "${_dst}.${_i}" ]; do _i=$((_i + 1)); done
        _dst="${_dst}.${_i}"
    fi
    mv "$_src" "$_dst" || _mh_die "Could not move $_src to $_dst"
    printf 'Archived %s -> %s\n' "$_name" "$_dst"
    _mh_register_quiet
}

mh_role() {
    _mh_require_install
    _name="$1"
    [ -z "$_name" ] && _mh_die "Usage: memory-hive role <name>"
    _cfile="$AGENTS_DIR/$_name/context.md"
    if [ ! -f "$_cfile" ]; then
        _mh_die "No such agent: $_name (looked for $_cfile)"
    fi
    _editor="${EDITOR:-vi}"
    # Run (don't exec) so we can refresh the registry after $EDITOR closes.
    # Errexit would abort the whole script if the editor exits non-zero
    # (e.g. user quit with :cq in vim); guard so we still run register.
    _editor_rc=0
    "$_editor" "$_cfile" || _editor_rc=$?
    _mh_register_quiet
    return "$_editor_rc"
}

mh_rename() {
    _mh_require_install
    _old="$1"; _new_raw="$2"
    [ -z "$_old" ] || [ -z "$_new_raw" ] && _mh_die "Usage: memory-hive rename <old> <new>"
    case "$_old" in
        main|_archived) _mh_die "'$_old' cannot be renamed." ;;
    esac
    _new="$(_mh_sanitize_name "$_new_raw")"
    if [ -z "$_new" ]; then
        _mh_die "New name must contain letters or digits (lowercase, dashes allowed)."
    fi
    if [ "$_new" = "main" ] || [ "$_new" = "_archived" ]; then
        _mh_die "'$_new' is a reserved name."
    fi
    _src="$AGENTS_DIR/$_old"
    _dst="$AGENTS_DIR/$_new"
    if [ ! -d "$_src" ]; then
        _mh_die "No such agent: $_old"
    fi
    if [ -e "$_dst" ]; then
        _mh_die "Target already exists: $_new"
    fi
    mv "$_src" "$_dst" || _mh_die "Could not rename $_src -> $_dst"
    printf 'Renamed %s -> %s\n' "$_old" "$_new"
    _mh_register_quiet
}

# --- dispatch ----------------------------------------------------------------

if [ $# -eq 0 ]; then
    mh_help
    exit 0
fi

_verb="$1"
shift
case "$_verb" in
    add)      mh_add "$@" ;;
    list|ls)  mh_list ;;
    archive)  mh_archive "$@" ;;
    role)     mh_role "$@" ;;
    rename)   mh_rename "$@" ;;
    register) _mh_require_install; mh_register; mh_citations >/dev/null 2>&1 || true ;;
    citations|cite) _mh_require_install; mh_citations ;;
    doctor)   mh_doctor "$@" ;;
    setup)    mh_setup ;;
    apply)    _mh_require_install; mh_apply "$@" ;;
    stats)    mh_stats ;;
    watch)    mh_watch ;;
    help|-h|--help) mh_help ;;
    *)
        printf 'Unknown command: %s\n\n' "$_verb" >&2
        mh_help >&2
        exit 2
        ;;
esac

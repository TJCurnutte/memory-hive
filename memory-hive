# mh_apply — detect running agent processes and tell the user how to
# restart them so the installer's managed block takes effect. Pure
# diagnostic by default; --force sends SIGTERM to CLI agents (not
# desktop apps — a shell installer has no business killing those).
mh_apply() {
    _force=0
    _yes=0
    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--force) _force=1 ;;
            -y|--yes)   _yes=1 ;;
            -h|--help)
                printf 'Usage: memory-hive apply [--force] [--yes]\n'
                printf '  Without --force: prints what to restart.\n'
                printf '  With --force:    SIGTERMs detected CLI agents (asks first unless --yes).\n'
                return 0
                ;;
            *) printf 'Unknown flag: %s\n' "$1" >&2; return 2 ;;
        esac
        shift
    done

    # Process name patterns we understand. Exact-match on basename so
    # we don't sweep up unrelated binaries. Keep this list conservative
    # — it's safer to miss a niche agent than to kill an unrelated
    # process that happens to match.
    _patterns='aider goose claude codex opencode crush'

    _found=""
    for _pat in $_patterns; do
        # pgrep -x = exact command-name match. Portable across macOS
        # and Linux; fails silently if pgrep isn't on PATH.
        _pids="$(pgrep -x "$_pat" 2>/dev/null || true)"
        [ -n "$_pids" ] || continue
        for _pid in $_pids; do
            # Skip our own shell + any parent in the tree.
            [ "$_pid" = "$$" ] && continue
            if [ -z "$_found" ]; then
                _found="$_pat:$_pid"
            else
                _found="$_found $_pat:$_pid"
            fi
        done
    done

    # Also note desktop apps — we won't touch them, but users need to
    # know a restart is required. Detection is best-effort: pgrep -f
    # against well-known app bundle names (macOS-ish). Doesn't populate
    # on Linux if the app binary has a different name; that's fine.
    _desktop=""
    for _app in "Claude" "Cursor" "Windsurf" "Zed" "Warp"; do
        if pgrep -x "$_app" >/dev/null 2>&1; then
            if [ -z "$_desktop" ]; then _desktop="$_app"; else _desktop="$_desktop $_app"; fi
        fi
    done

    if [ -z "$_found" ] && [ -z "$_desktop" ]; then
        printf 'No running agent processes detected. Nothing to apply.\n'
        printf 'Changes take effect the next time you start an agent.\n'
        return 0
    fi

    printf 'Agents detected:\n'
    if [ -n "$_found" ]; then
        for _entry in $_found; do
            _name="${_entry%%:*}"
            _pid="${_entry##*:}"
            printf '  CLI     %-10s pid=%s\n' "$_name" "$_pid"
        done
    fi
    if [ -n "$_desktop" ]; then
        for _app in $_desktop; do
            printf '  Desktop %-10s (quit + reopen to apply)\n' "$_app"
        done
    fi

    if [ "$_force" -ne 1 ]; then
        printf '\nTo restart the CLI agents, run:\n'
        if [ -n "$_found" ]; then
            for _entry in $_found; do
                _name="${_entry%%:*}"
                _pid="${_entry##*:}"
                printf '  kill %s  # %s — then re-run `%s` in your terminal\n' "$_pid" "$_name" "$_name"
            done
        fi
        if [ -n "$_desktop" ]; then
            printf '\nDesktop apps need a manual quit + reopen:\n'
            for _app in $_desktop; do
                printf '  - Quit and reopen %s\n' "$_app"
            done
        fi
        printf '\nRe-run with `memory-hive apply --force` to send SIGTERM to the CLI agents.\n'
        return 0
    fi

    # --force path: confirm unless --yes
    if [ "$_yes" -ne 1 ]; then
        printf '\n--force will SIGTERM every CLI agent listed above. Desktop apps are\n'
        printf 'never touched. Proceed? [y/N]: '
        _ans=""
        IFS= read -r _ans || return 1
        case "$_ans" in
            y|Y|yes|YES|Yes) ;;
            *) printf 'Aborted.\n'; return 0 ;;
        esac
    fi

    _killed=0
    _failed=0
    for _entry in $_found; do
        _name="${_entry%%:*}"
        _pid="${_entry##*:}"
        if kill "$_pid" 2>/dev/null; then
            printf '  SIGTERM %s (%s)\n' "$_pid" "$_name"
            _killed=$((_killed + 1))
        else
            printf '  FAILED  %s (%s) — permission or process gone\n' "$_pid" "$_name" >&2
            _failed=$((_failed + 1))
        fi
    done

    printf '\nDone. %d terminated, %d failed.\n' "$_killed" "$_failed"
    if [ -n "$_desktop" ]; then
        printf 'Desktop apps still need a manual quit + reopen: %s\n' "$_desktop"
    fi
    return 0
}

# --- telemetry: stats + watch ------------------------------------------------
#
# Every signal here comes from a real file write under $HIVE_DIR. We never
# count time-based "activations"; we count files whose mtime is newer than
# the window. That means:
#   - if no agent writes to its silo, the counter stays at zero
#   - if an agent claims to have written but didn't, the counter stays at zero
#   - counts always match what `ls -la` + `find -mtime` will show
# This is the anti-trick property the user asked for.

# _mh_classify <abspath> → prints `agent:kind` to stdout, or empty to skip.
# Maps a hive file path to (who did it, what kind of write it was).
_mh_classify() {
    _p="$1"
    # Normalize: strip HIVE_DIR prefix so we operate on relative paths.
    case "$_p" in
        "$HIVE_DIR"/*) _rel="${_p#"$HIVE_DIR"/}" ;;
        *) return 0 ;;
    esac
    case "$_rel" in
        agents/_archived/*)              return 0 ;;  # archived — don't count
        agents/*/log.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf '%s:log' "$_who" ;;
        agents/*/memory.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf '%s:memory' "$_who" ;;
        agents/*/context.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf '%s:context' "$_who" ;;
        agents/*/learnings/*.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf '%s:learning' "$_who" ;;
        learnings/raw/*/*.md)
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $3}')"
            printf '%s:raw' "$_who" ;;
        learnings/raw/*.md)
            printf 'unknown:raw' ;;
        learnings/distilled/*.md)
            printf 'curator:distilled' ;;
        curator/DECISIONS.md)            printf 'curator:decision' ;;
        curator/CONFLICTS.md)            printf 'curator:conflict' ;;
        curator/DRAFT.md)                printf 'curator:draft' ;;
        knowledge/*.md)                  printf 'curator:knowledge' ;;
        raw/*/*.md)                      # Tier 1 external ingestion
            _who="$(printf '%s' "$_rel" | awk -F/ '{print $2}')"
            printf 'ingester:%s' "$_who" ;;
        *) return 0 ;;
    esac
}

# _mh_hive_file_list — print one path per line for every file under $HIVE_DIR
# that counts as a hive write (skips .git, .upstream, .local backups, dirs).
_mh_hive_file_list() {
    [ -d "$HIVE_DIR" ] || return 0
    find "$HIVE_DIR" -type f \
        ! -name "*.upstream" \
        ! -name "*.local" \
        ! -name ".DS_Store" \
        ! -path "*/.git/*" \
        2>/dev/null
}

# _mh_mtime_epoch <path> → seconds since epoch (portable macOS + GNU).
_mh_mtime_epoch() {
    # GNU stat first (Linux), then BSD stat (macOS).
    stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null
}

# _mh_stale_raw_files [days] [agent]
# Print stale raw learnings as TAB-separated rows: <age_days>\t<agent>\t<path>
# (sorted by age descending — oldest first).
#
# A file is "stale" if:
#   - its mtime is older than <days> days ago (default 7)
#   - AND its basename does NOT appear anywhere in curator/DECISIONS.md
#     (heuristic for "unreviewed": the curator is expected to backlink the
#     filename when promoting/retiring; absent backlink ≈ untouched).
#
# Optional second arg filters to one agent's raw subdir.
#
# Heuristic note: this is mtime + DECISIONS.md grep. It can falsely flag a
# promoted-but-not-referenced file, and miss a referenced-but-still-untouched
# file. It's deliberately conservative — better than mtime-only, simpler
# than a frontmatter schema change.
_mh_stale_raw_files() {
    _days="${1:-7}"
    _filter_agent="${2:-}"
    _raw_root="$HIVE_DIR/learnings/raw"
    [ -d "$_raw_root" ] || return 0

    _now_s="$(date +%s)"
    _cutoff=$((_now_s - _days * 86400))
    _decisions="$HIVE_DIR/curator/DECISIONS.md"

    # Layout is learnings/raw/<agent>/<file>.md. Some installs may also have
    # learnings/raw/<file>.md (no agent dir); attribute those to "unknown".
    _tmp="${TMPDIR:-/tmp}/mh-stale.$$"
    : > "$_tmp"
    for _adir in "$_raw_root"/*; do
        [ -e "$_adir" ] || continue
        if [ -d "$_adir" ]; then
            _agent="$(basename "$_adir")"
            if [ -n "$_filter_agent" ] && [ "$_agent" != "$_filter_agent" ]; then
                continue
            fi
            for _f in "$_adir"/*.md; do
                [ -f "$_f" ] || continue
                _mt="$(_mh_mtime_epoch "$_f")"
                [ -n "$_mt" ] || continue
                [ "$_mt" -le "$_cutoff" ] || continue
                _base="$(basename "$_f")"
                if [ -f "$_decisions" ] && grep -q -F "$_base" "$_decisions" 2>/dev/null; then
                    continue
                fi
                _age=$(( (_now_s - _mt) / 86400 ))
                printf '%s\t%s\t%s\n' "$_age" "$_agent" "$_f" >> "$_tmp"
            done
        elif [ -f "$_adir" ]; then
            if [ -n "$_filter_agent" ] && [ "$_filter_agent" != "unknown" ]; then
                continue
            fi
            case "$_adir" in *.md) ;; *) continue ;; esac
            _mt="$(_mh_mtime_epoch "$_adir")"
            [ -n "$_mt" ] || continue
            [ "$_mt" -le "$_cutoff" ] || continue
            _base="$(basename "$_adir")"
            if [ -f "$_decisions" ] && grep -q -F "$_base" "$_decisions" 2>/dev/null; then
                continue
            fi
            _age=$(( (_now_s - _mt) / 86400 ))
            printf '%s\t%s\t%s\n' "$_age" "unknown" "$_adir" >> "$_tmp"
        fi
    done

    # POSIX-portable numeric sort, descending (oldest first).
    sort -k1,1nr "$_tmp" 2>/dev/null
    rm -f "$_tmp"
}

# _mh_fmt_time <epoch> → "HH:MM:SS" in local time.
_mh_fmt_time() {
    _e="$1"
    # GNU date accepts @epoch, BSD date accepts -r epoch. Try both.
    date -d "@$_e" '+%H:%M:%S' 2>/dev/null || date -r "$_e" '+%H:%M:%S' 2>/dev/null || printf '??:??:??'
}

# _mh_fmt_date <epoch> → "YYYY-MM-DD".
_mh_fmt_date() {
    _e="$1"
    date -d "@$_e" '+%Y-%m-%d' 2>/dev/null || date -r "$_e" '+%Y-%m-%d' 2>/dev/null || printf '????-??-??'
}

mh_stats() {
    _mh_require_install

    _now="$(date +%s)"
    # Start-of-today in local time.
    _today0="$(date -d 'today 00:00:00' +%s 2>/dev/null || date -v0H -v0M -v0S +%s 2>/dev/null || printf '%s' "$_now")"
    _week_ago=$((_now - 7 * 86400))

    # Baseline: the installer touches $HIVE_DIR/.baseline-installed as its
    # last step. Files with mtime <= baseline are installer scaffolding, not
    # agent activity, and get excluded from the counter. Without this the
    # counter lies on a fresh install ("13 writes" from the templates).
    _baseline_file="$HIVE_DIR/.baseline-installed"
    _baseline_mtime=0
    _baseline_missing=0
    if [ -f "$_baseline_file" ]; then
        _baseline_mtime="$(_mh_mtime_epoch "$_baseline_file")"
        [ -n "$_baseline_mtime" ] || _baseline_mtime=0
    else
        _baseline_missing=1
    fi

    # Pipeline emits records; aggregation happens after to keep counters.
    _mh_hive_file_list | while IFS= read -r _f; do
        _cls="$(_mh_classify "$_f")"
        [ -n "$_cls" ] || continue
        _mt="$(_mh_mtime_epoch "$_f")"
        [ -n "$_mt" ] || continue
        # Drop installer scaffolding (files touched at or before baseline).
        if [ "$_baseline_mtime" -gt 0 ] && [ "$_mt" -le "$_baseline_mtime" ]; then
            continue
        fi
        printf '%s\t%s\t%s\n' "$_mt" "$_cls" "$_f"
    done | sort -nr > /tmp/mh-stats.$$

    _total=0; _today=0; _week=0
    _agent_tally=""
    _kind_tally=""
    _latest_row=""
    while IFS=$(printf '\t') read -r _mt _cls _f; do
        [ -n "$_mt" ] || continue
        _total=$((_total + 1))
        [ "$_mt" -ge "$_today0" ] && _today=$((_today + 1))
        [ "$_mt" -ge "$_week_ago" ] && _week=$((_week + 1))
        _who="${_cls%%:*}"
        _kind="${_cls##*:}"
        _agent_tally="$_agent_tally $_who"
        _kind_tally="$_kind_tally $_kind"
        [ -z "$_latest_row" ] && _latest_row="$_mt|$_cls|$_f"
    done < /tmp/mh-stats.$$
    rm -f /tmp/mh-stats.$$

    # --- render -------------------------------------------------------------
    printf '\nMemory Hive — activity\n'
    printf 'Hive: %s\n' "$HIVE_DIR"
    if [ "$_baseline_missing" -eq 1 ]; then
        printf '\n  (no .baseline-installed marker — re-run the installer to set it;\n'
        printf '   stats below include install-time scaffolding until then)\n'
    else
        printf 'Since install: %s\n' "$(_mh_fmt_date "$_baseline_mtime")"
    fi
    printf '\n'
    printf '  %-14s %s\n' "Today:"       "$_today writes"
    printf '  %-14s %s\n' "Last 7 days:" "$_week writes"
    printf '  %-14s %s\n' "All-time:"    "$_total writes"

    if [ "$_total" -eq 0 ]; then
        printf '\n  (no agent has written to the hive yet — run a task and come back)\n'
        printf '\n  Every count here corresponds to a file under %s\n' "$HIVE_DIR"
        printf '  whose mtime is newer than the install baseline.\n'
        printf '  Verify with: find %s -type f -newer %s\n\n' "$HIVE_DIR" "$_baseline_file"
        return 0
    fi

    printf '\nBy agent:\n'
    printf '%s\n' $_agent_tally | sort | uniq -c | sort -rn | while read _c _a; do
        printf '  %-24s %s\n' "$_a" "$_c"
    done

    printf '\nBy kind:\n'
    printf '%s\n' $_kind_tally | sort | uniq -c | sort -rn | while read _c _k; do
        printf '  %-24s %s\n' "$_k" "$_c"
    done

    if [ -n "$_latest_row" ]; then
        _mt="${_latest_row%%|*}"
        _rest="${_latest_row#*|}"
        _cls="${_rest%%|*}"
        _f="${_rest#*|}"
        _rel="${_f#"$HIVE_DIR"/}"
        printf '\nMost recent write: %s · %s · %s\n' "$(_mh_fmt_date "$_mt") $(_mh_fmt_time "$_mt")" "$_cls" "$_rel"
    fi

    # Honest-by-construction footer — tells users how to verify independently.
    printf '\nVerify: find %s -type f -newer %s\n\n' "$HIVE_DIR" "$_baseline_file"
}

# mh_watch — live stream. Uses the best available watcher.
mh_watch() {
    _mh_require_install
    [ -d "$HIVE_DIR" ] || _mh_die "Hive directory missing: $HIVE_DIR"

    printf 'Memory Hive — live activity  (Ctrl+C to exit)\n'
    printf 'Watching: %s\n' "$HIVE_DIR"
    printf '──────────────────────────────────────────────\n'

    _session_count=0

    # _handle_event <path> — classify, count, print. Called for each event.
    _handle_event() {
        _path="$1"
        [ -f "$_path" ] || return 0
        _cls="$(_mh_classify "$_path")"
        [ -n "$_cls" ] || return 0
        _mt="$(_mh_mtime_epoch "$_path")"
        [ -n "$_mt" ] || _mt="$(date +%s)"
        _session_count=$((_session_count + 1))
        _who="${_cls%%:*}"
        _kind="${_cls##*:}"
        _rel="${_path#"$HIVE_DIR"/}"
        printf '%s  [%03d]  %-18s %-10s %s\n' \
            "$(_mh_fmt_time "$_mt")" "$_session_count" "$_who" "$_kind" "$_rel"
    }

    if command -v fswatch >/dev/null 2>&1; then
        # macOS / portable — fswatch emits one path per line.
        fswatch -0 "$HIVE_DIR" 2>/dev/null | while IFS= read -r -d '' _path; do
            _handle_event "$_path"
        done
    elif command -v inotifywait >/dev/null 2>&1; then
        # Linux — inotifywait with -m keeps streaming.
        inotifywait -mrq -e close_write,create,modify --format '%w%f' "$HIVE_DIR" 2>/dev/null | while IFS= read -r _path; do
            _handle_event "$_path"
        done
    else
        # Polling fallback: scan every 5s for files modified since the last
        # scan. Uses a sentinel file for the time reference (portable vs.
        # `find -newermt "<date>"` which isn't POSIX).
        _sentinel="$(mktemp -t mh-watch.XXXXXX)"
        printf '(polling every 5s — install fswatch or inotify-tools for instant updates)\n'
        while :; do
            sleep 5
            _newer=""
            # -newer <file> is POSIX. Collect changed files into a list.
            _newer="$(find "$HIVE_DIR" -type f -newer "$_sentinel" 2>/dev/null \
                ! -name '*.upstream' ! -name '*.local' ! -name '.DS_Store' \
                ! -path '*/.git/*')"
            touch "$_sentinel"
            [ -z "$_newer" ] && continue
            printf '%s\n' "$_newer" | while IFS= read -r _path; do
                [ -n "$_path" ] && _handle_event "$_path"
            done
        done
    fi
}

# --- tail: most-recent writes with content -----------------------------------
#
# `memory-hive tail` shows the N newest hive writes and, for each, the key
# lines from the file. Different file kinds get different extraction:
#   * log.md, DECISIONS.md, CONFLICTS.md  — newest "## YYYY-MM-DD" heading
#                                           and the first paragraph under it
#   * memory.md, context.md               — last ~10 non-blank lines
#   * learnings (raw or distilled),       — first H1 + YAML frontmatter
#     knowledge/*.md
#   * anything else classifiable          — first H1 only
#
# Always exits after printing; `memory-hive watch` already covers streaming.

# _mh_extract_dated_section <abspath>
# Print the newest "## YYYY-MM-DD..." heading line and every following line up
# to (but not including) the next blank line, the next "## " heading, or EOF.
# Indented two spaces so the result nests under the file path in the listing.
# Falls back to the first 5 non-blank, non-heading lines if no dated section.
_mh_extract_dated_section() {
    awk '
        BEGIN { found = 0; phase = 0; n = 0 }
        # phase 0 = before heading
        # phase 1 = found heading, skipping leading blanks
        # phase 2 = inside the first paragraph
        # Newest dated heading: file convention is newest-first, so the first
        # one we see wins.
        found == 0 && /^## [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/ {
            found = 1
            phase = 1
            print "  " $0
            next
        }
        phase == 1 {
            # Bail on a new "## " heading immediately.
            if ($0 ~ /^## /) { exit }
            # Skip blank padding between heading and body.
            if ($0 ~ /^[[:space:]]*$/) next
            # First content line — start the body.
            phase = 2
            print "  " $0
            n++
            if (n >= 8) exit
            next
        }
        phase == 2 {
            # Stop at next "## " heading or a blank line (paragraph break).
            if ($0 ~ /^## /) exit
            if ($0 ~ /^[[:space:]]*$/) exit
            print "  " $0
            n++
            if (n >= 8) exit
        }
    ' "$1"
}

# _mh_extract_tail_lines <abspath>
# Print the last 10 non-blank lines of the file, indented two spaces. Used for
# memory.md / context.md where the user is appending bullets and there is no
# dated structure to anchor on.
_mh_extract_tail_lines() {
    awk '
        { lines[NR] = $0 }
        END {
            start = NR - 30
            if (start < 1) start = 1
            kept = 0
            # Walk forward from start; collect non-blank lines.
            for (i = start; i <= NR; i++) {
                if (lines[i] ~ /^[[:space:]]*$/) continue
                buf[++kept] = lines[i]
            }
            first = kept - 9
            if (first < 1) first = 1
            for (i = first; i <= kept; i++) print "  " buf[i]
        }
    ' "$1"
}

# _mh_extract_learning <abspath>
# Print YAML frontmatter (between leading --- / ---) plus the first H1 line.
# Frontmatter is what tells the curator what the learning is about; the H1 is
# the human-readable title. Both indented two spaces.
_mh_extract_learning() {
    awk '
        BEGIN { fm = 0; fm_done = 0; h1_done = 0; line = 0 }
        {
            line++
            if (line == 1 && $0 == "---") { fm = 1; print "  ---"; next }
            if (fm == 1 && fm_done == 0) {
                if ($0 == "---") { print "  ---"; fm_done = 1; next }
                print "  " $0
                next
            }
            if (h1_done == 0 && $0 ~ /^# /) {
                print "  " $0
                h1_done = 1
                exit
            }
        }
    ' "$1"
}

# _mh_extract_h1 <abspath>
# Last-resort fallback: just the first H1.
_mh_extract_h1() {
    awk '/^# / { print "  " $0; exit }' "$1"
}

# _mh_extract_for_kind <kind> <abspath>
# Dispatch to the right extractor based on the classifier kind. Falls back to
# tail-lines when the dated extractor finds no heading (some log.md files do
# not yet use the YYYY-MM-DD convention).
_mh_extract_for_kind() {
    _kind="$1"
    _path="$2"
    case "$_kind" in
        log|decision|conflict|draft)
            _out="$(_mh_extract_dated_section "$_path")"
            if [ -z "$_out" ]; then
                _mh_extract_tail_lines "$_path"
            else
                printf '%s\n' "$_out"
            fi
            ;;
        memory|context)
            _mh_extract_tail_lines "$_path"
            ;;
        raw|distilled|learning|knowledge)
            _out="$(_mh_extract_learning "$_path")"
            if [ -z "$_out" ]; then
                _mh_extract_h1 "$_path"
            else
                printf '%s\n' "$_out"
            fi
            ;;
        *)
            _mh_extract_h1 "$_path"
            ;;
    esac
}

mh_tail() {
    _mh_require_install

    _count=10
    _silo=""
    _since_date=""
    _since_epoch=0

    while [ $# -gt 0 ]; do
        case "$1" in
            -n|--count)
                shift
                [ $# -gt 0 ] || _mh_die "-n/--count needs a value"
                _count="$1"
                shift
                ;;
            -n=*)   _count="${1#-n=}"; shift ;;
            --count=*) _count="${1#--count=}"; shift ;;
            --silo)
                shift
                [ $# -gt 0 ] || _mh_die "--silo needs a value"
                _silo="$1"
                shift
                ;;
            --silo=*) _silo="${1#--silo=}"; shift ;;
            --since)
                shift
                [ $# -gt 0 ] || _mh_die "--since needs a value (YYYY-MM-DD)"
                _since_date="$1"
                shift
                ;;
            --since=*) _since_date="${1#--since=}"; shift ;;
            -h|--help)
                printf 'Usage: memory-hive tail [-n <N>] [--silo <name>] [--since <YYYY-MM-DD>]\n'
                printf '  Show the N most recent hive writes with key content from each.\n'
                printf '  Default N=10, cap 100. Always exits after printing.\n'
                return 0
                ;;
            *)
                _mh_die "Unknown argument: $1"
                ;;
        esac
    done

    # Validate count: positive integer, capped at 100.
    case "$_count" in
        ''|*[!0-9]*) _mh_die "-n/--count must be a positive integer (got: $_count)" ;;
    esac
    [ "$_count" -ge 1 ] || _mh_die "-n/--count must be >= 1"
    [ "$_count" -le 100 ] || _count=100

    # Validate / convert --since to epoch.
    if [ -n "$_since_date" ]; then
        case "$_since_date" in
            [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]) ;;
            *) _mh_die "--since must be YYYY-MM-DD (got: $_since_date)" ;;
        esac
        _since_epoch="$(date -d "$_since_date 00:00:00" +%s 2>/dev/null \
            || date -j -f '%Y-%m-%d %H:%M:%S' "$_since_date 00:00:00" +%s 2>/dev/null \
            || printf '0')"
        [ "$_since_epoch" -gt 0 ] || _mh_die "could not parse --since date: $_since_date"
    fi

    # Baseline (mirror mh_stats): exclude install-time scaffolding.
    _baseline_file="$HIVE_DIR/.baseline-installed"
    _baseline_mtime=0
    if [ -f "$_baseline_file" ]; then
        _baseline_mtime="$(_mh_mtime_epoch "$_baseline_file")"
        [ -n "$_baseline_mtime" ] || _baseline_mtime=0
    fi

    # Build a sorted list of <mtime>\t<class>\t<path> for files that:
    #   * classify (skips _archived, junk, etc.)
    #   * are newer than baseline
    #   * match --silo if given
    #   * are on/after --since if given
    _tmp="${TMPDIR:-/tmp}/mh-tail.$$"
    _mh_hive_file_list | while IFS= read -r _f; do
        _cls="$(_mh_classify "$_f")"
        [ -n "$_cls" ] || continue
        _who="${_cls%%:*}"
        if [ -n "$_silo" ] && [ "$_who" != "$_silo" ]; then
            continue
        fi
        _mt="$(_mh_mtime_epoch "$_f")"
        [ -n "$_mt" ] || continue
        if [ "$_baseline_mtime" -gt 0 ] && [ "$_mt" -le "$_baseline_mtime" ]; then
            continue
        fi
        if [ "$_since_epoch" -gt 0 ] && [ "$_mt" -lt "$_since_epoch" ]; then
            continue
        fi
        printf '%s\t%s\t%s\n' "$_mt" "$_cls" "$_f"
    done | sort -nr | head -n "$_count" > "$_tmp"

    # Header.
    printf '\nMemory Hive — last %s writes' "$_count"
    [ -n "$_silo" ] && printf ' (silo: %s)' "$_silo"
    [ -n "$_since_date" ] && printf ' (since %s)' "$_since_date"
    printf '\n'
    printf '────────────────────────────\n\n'

    if [ ! -s "$_tmp" ]; then
        printf '  (no writes match)\n\n'
        rm -f "$_tmp"
        return 0
    fi

    # Render each row.
    while IFS=$(printf '\t') read -r _mt _cls _f; do
        [ -n "$_mt" ] || continue
        _who="${_cls%%:*}"
        _kind="${_cls##*:}"
        _rel="${_f#"$HIVE_DIR"/}"
        # Heading line: HH:MM:SS  agent  rel/path
        printf '%s  %-10s %s\n' "$(_mh_fmt_time "$_mt")" "$_who" "$_rel"
        # Body — capped at 8 indented lines so 100 entries does not blow the
        # terminal. Extractors already self-cap; this is a hard ceiling.
        _mh_extract_for_kind "$_kind" "$_f" | head -n 8
        printf '\n'
    done < "$_tmp"

    rm -f "$_tmp"
    return 0
}

mh_setup() {
    _mh_require_install
    _installer="$INSTALL_DIR/install.sh"
    if [ ! -f "$_installer" ]; then
        printf 'ERROR: installer not found at %s\n' "$_installer" >&2
        printf 'Re-run the install to restore it:\n' >&2
        printf '  curl -fsSL https://raw.githubusercontent.com/TJCurnutte/memory-hive/main/install.sh | sh\n' >&2
        return 1
    fi
    MEMORY_HIVE_WIZARD=1 MEMORY_HIVE_DIR="$INSTALL_DIR" \
        MEMORY_HIVE_SKIP_CLAUDE_MD="${MEMORY_HIVE_SKIP_CLAUDE_MD:-1}" \
        sh "$_installer"
}

# --- query: searchable hive ---------------------------------------------------
#
# `memory-hive query <term>` — grep across every text surface of the hive so
# nothing the user (or an agent) wrote becomes write-only. We grep $HIVE_DIR
# directly instead of reusing _mh_classify because the search target is
# broader (every .md under hive/, including curator/, registry/, raw/,
# knowledge/). Skips _archived/, .git, .upstream/.local backups, and
# dotfiles by construction.
#
# Defaults to fixed-string match (`grep -F`); pass --regex to opt into ERE.
# Honest-first: if the term contains regex metacharacters and --regex was
# NOT passed, we warn the user once before running so a mistyped query
# doesn't silently treat the regex as a literal.

# _mh_query_has_regex_meta <term> — return 0 if the term contains characters
# that mean something different in regex than literal text. Conservative
# list: . * + ? ( ) [ ] { } ^ $ | \. We don't flag - or _ even though
# they're technically regex-significant inside character classes.
_mh_query_has_regex_meta() {
    case "$1" in
        *[.*+?\(\)\[\]\{\}\^\$\|\\]*) return 0 ;;
        *) return 1 ;;
    esac
}

# _mh_query_classify_path <abspath> — prints the file's "kind" (log,
# memory, context, learning, distilled, raw, knowledge, curator, registry,
# other). Used by --kind filtering. Path-driven and intentionally simple
# — we trust the on-disk layout the installer creates.
_mh_query_classify_path() {
    case "$1" in
        "$HIVE_DIR"/*) _qrel="${1#"$HIVE_DIR"/}" ;;
        *) printf 'other'; return 0 ;;
    esac
    case "$_qrel" in
        agents/*/log.md)            printf 'log' ;;
        agents/*/memory.md)         printf 'memory' ;;
        agents/*/context.md)        printf 'context' ;;
        agents/*/learnings/*.md)    printf 'learning' ;;
        learnings/raw/*)            printf 'raw' ;;
        learnings/distilled/*)      printf 'distilled' ;;
        knowledge/*)                printf 'knowledge' ;;
        curator/*)                  printf 'curator' ;;
        registry/*)                 printf 'registry' ;;
        raw/*)                      printf 'raw' ;;
        *)                          printf 'other' ;;
    esac
}

# _mh_query_file_list — print one absolute path per line for every text
# file under $HIVE_DIR that is in scope for query. Mirrors
# _mh_hive_file_list (skipping .git/.upstream/.local/.DS_Store) plus
# extra excludes for _archived/ and dotfiles, and limits to .md files.
# Sanitized agent names guarantee no spaces/newlines in path segments.
_mh_query_file_list() {
    [ -d "$HIVE_DIR" ] || return 0
    find "$HIVE_DIR" -type f -name '*.md' \
        ! -path "*/_archived/*" \
        ! -path "*/.git/*" \
        ! -name '.*' \
        ! -name "*.upstream" \
        ! -name "*.local" \
        ! -name ".DS_Store" \
        2>/dev/null
}

# _mh_query_highlight <term> <line> — re-emit the line with ANSI bold-red
# wrapped around every literal occurrence of <term>. Used only when stdout
# is a tty. We sed-escape the term so regex metacharacters don't blow up
# the s/// pattern.
_mh_query_highlight() {
    _term="$1"
    _line="$2"
    _esc="$(printf '%s' "$_term" | sed -e 's/[\.[\*^$/&#]/\\&/g')"
    _hl_open="$(printf '\033[1;31m')"
    _hl_close="$(printf '\033[0m')"
    printf '%s' "$_line" | sed "s#${_esc}#${_hl_open}&${_hl_close}#g"
}

mh_query() {
    _mh_require_install

    _q_term=""
    _q_silo=""
    _q_kind=""
    _q_since=""
    _q_paths_only=0
    _q_regex=0
    _q_max_per_file=10

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                cat <<'EOF'
Usage: memory-hive query <term> [flags]

Searches every text surface of the hive for <term>:
  agents/*/log.md, memory.md, context.md
  agents/*/learnings/*.md
  learnings/raw/**/*.md, learnings/distilled/*.md
  knowledge/*.md, curator/*.md, registry/*.md, raw/**/*.md

Flags:
  --silo <name>            Limit to that agent's silo.
  --kind <k>               Scope by classification:
                             log | memory | context | learning |
                             raw | distilled | knowledge | curator | registry
  --since <YYYY-MM-DD>     Only files modified on/after that date.
  --paths-only             Print matching paths, no content.
  --regex                  Treat <term> as an extended regular expression
                             (default is fixed-string).

Exits 1 if there are no matches (so it pipes cleanly into shell conditionals).

Examples:
  memory-hive query "circular import"
  memory-hive query api --silo coder --kind memory
  memory-hive query 2026-04 --kind log --since 2026-04-20
  memory-hive query --regex 'TODO|FIXME' --paths-only
EOF
                return 0
                ;;
            --silo)
                shift
                [ $# -gt 0 ] || _mh_die "--silo needs a value"
                _q_silo="$1"; shift ;;
            --silo=*)  _q_silo="${1#--silo=}"; shift ;;
            --kind)
                shift
                [ $# -gt 0 ] || _mh_die "--kind needs a value"
                _q_kind="$1"; shift ;;
            --kind=*)  _q_kind="${1#--kind=}"; shift ;;
            --since)
                shift
                [ $# -gt 0 ] || _mh_die "--since needs a value"
                _q_since="$1"; shift ;;
            --since=*) _q_since="${1#--since=}"; shift ;;
            --paths-only) _q_paths_only=1; shift ;;
            --regex)      _q_regex=1; shift ;;
            --) shift; _q_term="$1"; shift; break ;;
            -*) _mh_die "Unknown flag: $1 (try --help)" ;;
            *)
                if [ -z "$_q_term" ]; then
                    _q_term="$1"
                else
                    _mh_die "Unexpected argument: $1 (only one term; quote multi-word queries)"
                fi
                shift
                ;;
        esac
    done

    [ -n "$_q_term" ] || _mh_die "Usage: memory-hive query <term> [flags]   (try --help)"

    # Validate --kind early so a typo fails before the search runs.
    if [ -n "$_q_kind" ]; then
        case "$_q_kind" in
            log|memory|context|learning|raw|distilled|knowledge|curator|registry) ;;
            *) _mh_die "Unknown --kind '$_q_kind'. Valid: log memory context learning raw distilled knowledge curator registry" ;;
        esac
    fi

    # Validate --silo (must be a real on-disk silo; refuse archived/hidden).
    if [ -n "$_q_silo" ]; then
        case "$_q_silo" in
            _archived|.*) _mh_die "Cannot search archived or hidden silos." ;;
        esac
        if [ ! -d "$AGENTS_DIR/$_q_silo" ]; then
            _mh_die "No such silo: $_q_silo"
        fi
    fi

    # Validate --since (YYYY-MM-DD only — keep parsing simple + portable).
    _q_since_epoch=0
    if [ -n "$_q_since" ]; then
        case "$_q_since" in
            [0-9][0-9][0-9][0-9]-[0-1][0-9]-[0-3][0-9]) ;;
            *) _mh_die "--since must be YYYY-MM-DD (got: $_q_since)" ;;
        esac
        # GNU date first, BSD date second.
        _q_since_epoch="$(date -d "$_q_since 00:00:00" +%s 2>/dev/null \
            || date -j -f '%Y-%m-%d %H:%M:%S' "$_q_since 00:00:00" +%s 2>/dev/null \
            || printf '0')"
        [ "$_q_since_epoch" -gt 0 ] || _mh_die "Could not parse --since date: $_q_since"
    fi

    # Honest warning: regex metas in a fixed-string query are usually a mistake.
    if [ "$_q_regex" -eq 0 ] && _mh_query_has_regex_meta "$_q_term"; then
        printf '(note: "%s" contains regex metacharacters but is being treated literally;\n' "$_q_term" >&2
        printf '       pass --regex if you meant a regular expression)\n\n' >&2
    fi

    # Tty-aware highlighting. Only colorize when stdout is a real terminal.
    _q_color=0
    [ -t 1 ] && _q_color=1

    # Pick grep flavor. -F = fixed-string (default), -E = extended regex.
    if [ "$_q_regex" -eq 1 ]; then
        _q_grep_flag="-E"
    else
        _q_grep_flag="-F"
    fi

    # Build the candidate file list with --silo / --kind / --since applied
    # up front, so we never grep files that don't qualify and per-file
    # output ordering stays deterministic.
    _q_files="$INSTALL_DIR/.query-files.$$"
    _mh_query_file_list | while IFS= read -r _f; do
        [ -n "$_f" ] || continue
        if [ -n "$_q_silo" ]; then
            case "$_f" in
                "$AGENTS_DIR/$_q_silo"/*) ;;
                *) continue ;;
            esac
        fi
        if [ -n "$_q_kind" ]; then
            _fkind="$(_mh_query_classify_path "$_f")"
            [ "$_fkind" = "$_q_kind" ] || continue
        fi
        if [ "$_q_since_epoch" -gt 0 ]; then
            _fmt="$(_mh_mtime_epoch "$_f")"
            [ -n "$_fmt" ] || continue
            [ "$_fmt" -ge "$_q_since_epoch" ] || continue
        fi
        printf '%s\n' "$_f"
    done | sort > "$_q_files"

    if [ ! -s "$_q_files" ]; then
        rm -f "$_q_files"
        printf 'No files in scope for query.\n' >&2
        return 1
    fi

    # --- search loop -------------------------------------------------------
    # Per-file grep with line numbers, capped at $_q_max_per_file rows.
    # Counters live in a temp file because the while-pipeline runs in a
    # subshell on POSIX sh and any plain-shell counters wouldn't survive.
    _q_counts="$INSTALL_DIR/.query-counts.$$"
    : > "$_q_counts"
    _q_first=1

    while IFS= read -r _f; do
        [ -n "$_f" ] || continue
        # -n line numbers, -I skip binary, -h no filename (we print our own).
        _q_hits="$(grep -nIh "$_q_grep_flag" -e "$_q_term" "$_f" 2>/dev/null || true)"
        [ -n "$_q_hits" ] || continue

        _q_count="$(printf '%s\n' "$_q_hits" | wc -l | tr -d ' ')"
        printf 'F\n' >> "$_q_counts"
        _i=0
        while [ "$_i" -lt "$_q_count" ]; do
            printf 'M\n' >> "$_q_counts"
            _i=$((_i + 1))
        done

        if [ "$_q_paths_only" -eq 1 ]; then
            printf '%s\n' "${_f#"$HIVE_DIR"/}"
            continue
        fi

        # Heading style cribbed from rg: blank line between files, cyan-bold
        # path (when tty), then `line:content` rows.
        if [ "$_q_first" -eq 0 ]; then printf '\n'; fi
        _q_first=0

        _qrel="${_f#"$HIVE_DIR"/}"
        if [ "$_q_color" -eq 1 ]; then
            printf '\033[1;36m%s\033[0m\n' "$_qrel"
        else
            printf '%s\n' "$_qrel"
        fi

        # Cap per-file rows in a subshell so its counters don't bleed into
        # the outer while-loop.
        printf '%s\n' "$_q_hits" | (
            _shown=0
            _truncated=0
            while IFS= read -r _row; do
                [ -n "$_row" ] || continue
                _shown=$((_shown + 1))
                if [ "$_shown" -gt "$_q_max_per_file" ]; then
                    _truncated=1
                    break
                fi
                # Chop "lineno:content" at the first colon only — content
                # itself may contain colons.
                _ln="${_row%%:*}"
                _body="${_row#*:}"
                if [ "$_q_color" -eq 1 ]; then
                    _body_hl="$(_mh_query_highlight "$_q_term" "$_body")"
                    printf '  \033[2m%s\033[0m: %s\n' "$_ln" "$_body_hl"
                else
                    printf '  %s: %s\n' "$_ln" "$_body"
                fi
            done
            if [ "$_truncated" -eq 1 ]; then
                _more=$((_q_count - _q_max_per_file))
                printf '  ... +%s more match(es) in this file\n' "$_more"
            fi
        )
    done < "$_q_files"
    rm -f "$_q_files"

    # Aggregate counters from the temp file. Use wc -l rather than grep -c
    # because grep -c exits non-zero on zero matches, which would force a
    # fallback path; wc -l is unconditional. tr strips macOS' leading spaces.
    if [ -s "$_q_counts" ]; then
        _q_total_files="$(grep '^F$' "$_q_counts" 2>/dev/null | wc -l | tr -d ' ')"
        _q_total_matches="$(grep '^M$' "$_q_counts" 2>/dev/null | wc -l | tr -d ' ')"
    else
        _q_total_files=0
        _q_total_matches=0
    fi
    rm -f "$_q_counts"

    if [ "$_q_total_matches" -eq 0 ]; then
        printf 'No matches for "%s".\n' "$_q_term" >&2
        return 1
    fi

    if [ "$_q_paths_only" -eq 0 ]; then
        printf '\n'
    fi
    if [ "$_q_color" -eq 1 ]; then
        printf '\033[2m%s match(es) across %s file(s).\033[0m\n' \
            "$_q_total_matches" "$_q_total_files" >&2
    else
        printf '%s match(es) across %s file(s).\n' \
            "$_q_total_matches" "$_q_total_files" >&2
    fi
    return 0
}

mh_list() {
    _mh_require_install
    if [ ! -d "$AGENTS_DIR" ]; then
        printf '(no agents yet)\n'
        return 0
    fi
    _found=0
    for _p in "$AGENTS_DIR"/*; do
        [ -d "$_p" ] || continue
        _n="$(basename "$_p")"
        case "$_n" in
            _archived|.*) continue ;;
        esac
        _found=1
        # Try to pull the first non-placeholder line from ## Role in context.md.
        _role_summary=""
        _cfile="$_p/context.md"
        if [ -f "$_cfile" ]; then
            _role_summary="$(awk '
                /^## Role$/ { inrole = 1; next }
                inrole == 1 && /^## / { exit }
                inrole == 1 {
                    # Skip blank lines and placeholder parenthetical prompts.
                    if ($0 ~ /^[[:space:]]*$/) next
                    if ($0 ~ /^\([^)]*\)$/) next
                    print
                    exit
                }
            ' "$_cfile")"
        fi
        if [ -n "$_role_summary" ]; then
            # Trim to ~70 chars for one-line display.
            _role_summary="$(printf '%s' "$_role_summary" | cut -c1-70)"
            printf '  %-20s %s\n' "$_n" "$_role_summary"
        else
            printf '  %-20s (no role set)\n' "$_n"
        fi
    done
    if [ "$_found" -eq 0 ]; then
        printf '(no agents yet)\n'
    fi
}

mh_add() {
    _mh_require_install
    _name_raw="$1"
    shift || true
    if [ -z "$_name_raw" ]; then
        _mh_die "Usage: memory-hive add <name> [--role <template|path>]"
    fi
    _role_arg=""
    # Parse remaining args. Only --role is supported for now.
    while [ $# -gt 0 ]; do
        case "$1" in
            --role)
                shift
                if [ $# -eq 0 ]; then
                    _mh_die "--role needs a value (template name or path)"
                fi
                _role_arg="$1"
                shift
                ;;
            --role=*)
                _role_arg="${1#--role=}"
                shift
                ;;
            *)
                _mh_die "Unknown argument: $1"
                ;;
        esac
    done

    _name="$(_mh_sanitize_name "$_name_raw")"
    if [ -z "$_name" ]; then
        _mh_die "Name must contain letters or digits (lowercase, dashes allowed)."
    fi
    if [ "$_name" = "main" ] || [ "$_name" = "_archived" ]; then
        _mh_die "'$_name' is a reserved name."
    fi
    if [ -d "$AGENTS_DIR/$_name" ]; then
        _mh_die "Agent '$_name' already exists at $AGENTS_DIR/$_name"
    fi

    _role_text=""
    if [ -n "$_role_arg" ]; then
        _role_text="$(_mh_resolve_role "$_role_arg")"
    fi

    if [ ! -f "$CREATE_AGENT" ]; then
        _mh_die "create-agent.sh missing at $CREATE_AGENT — reinstall Memory Hive."
    fi

    if [ -n "$_role_text" ]; then
        MH_AGENT_ROLE="$_role_text" \
            MEMORY_HIVE_DIR="$INSTALL_DIR" \
            sh "$CREATE_AGENT" "$_name"
    else
        MEMORY_HIVE_DIR="$INSTALL_DIR" \
            sh "$CREATE_AGENT" "$_name"
    fi
    _mh_register_quiet
}

mh_archive() {
    _mh_require_install
    _name="$1"
    [ -z "$_name" ] && _mh_die "Usage: memory-hive archive <name>"
    case "$_name" in
        main|_archived) _mh_die "'$_name' cannot be archived." ;;
    esac
    _src="$AGENTS_DIR/$_name"
    if [ ! -d "$_src" ]; then
        _mh_die "No such agent: $_name (looked in $_src)"
    fi
    _date="$(date -u +%Y-%m-%d 2>/dev/null || echo "today")"
    _arch_root="$AGENTS_DIR/_archived/$_date"
    mkdir -p "$_arch_root" || _mh_die "Could not create $_arch_root"
    _dst="$_arch_root/$_name"
    if [ -e "$_dst" ]; then
        _i=1
        while [ -e "${_dst}.${_i}" ]; do _i=$((_i + 1)); done
        _dst="${_dst}.${_i}"
    fi
    mv "$_src" "$_dst" || _mh_die "Could not move $_src to $_dst"
    printf 'Archived %s -> %s\n' "$_name" "$_dst"
    _mh_register_quiet
}

mh_role() {
    _mh_require_install
    _name="$1"
    [ -z "$_name" ] && _mh_die "Usage: memory-hive role <name>"
    _cfile="$AGENTS_DIR/$_name/context.md"
    if [ ! -f "$_cfile" ]; then
        _mh_die "No such agent: $_name (looked for $_cfile)"
    fi
    _editor="${EDITOR:-vi}"
    # Run (don't exec) so we can refresh the registry after $EDITOR closes.
    # Errexit would abort the whole script if the editor exits non-zero
    # (e.g. user quit with :cq in vim); guard so we still run register.
    _editor_rc=0
    "$_editor" "$_cfile" || _editor_rc=$?
    _mh_register_quiet
    return "$_editor_rc"
}

mh_rename() {
    _mh_require_install
    _old="$1"; _new_raw="$2"
    [ -z "$_old" ] || [ -z "$_new_raw" ] && _mh_die "Usage: memory-hive rename <old> <new>"
    case "$_old" in
        main|_archived) _mh_die "'$_old' cannot be renamed." ;;
    esac
    _new="$(_mh_sanitize_name "$_new_raw")"
    if [ -z "$_new" ]; then
        _mh_die "New name must contain letters or digits (lowercase, dashes allowed)."
    fi
    if [ "$_new" = "main" ] || [ "$_new" = "_archived" ]; then
        _mh_die "'$_new' is a reserved name."
    fi
    _src="$AGENTS_DIR/$_old"
    _dst="$AGENTS_DIR/$_new"
    if [ ! -d "$_src" ]; then
        _mh_die "No such agent: $_old"
    fi
    if [ -e "$_dst" ]; then
        _mh_die "Target already exists: $_new"
    fi
    mv "$_src" "$_dst" || _mh_die "Could not rename $_src -> $_dst"
    printf 'Renamed %s -> %s\n' "$_old" "$_new"
    _mh_register_quiet
}

# --- promote -----------------------------------------------------------------
#
# Move (cite, really) a raw learning into a distilled file with one command.
#
# Why: the curator loop says "review raw, promote valuable, log decision".
# Doing that by hand is mv + diff + edit + open DECISIONS.md + type. Friction
# kills the loop. This verb collapses it to one command:
#
#   memory-hive promote learnings/raw/coder/2026-04-23-test-isolation.md
#
# Mechanics: append a summary with a backlink to the distilled file, append a
# dated entry to curator/DECISIONS.md, regenerate the registry. The raw file
# stays put -- it's the source of truth. Distilled cites raw, never copies it
# verbatim.

# _mh_promote_extract_frontmatter <file> <key> -> prints value to stdout, or
# empty if key not found. Reads only the first frontmatter block.
_mh_promote_extract_frontmatter() {
    _file="$1"
    _key="$2"
    awk -v k="$_key" '
        BEGIN { inf = 0 }
        NR == 1 && /^---[[:space:]]*$/ { inf = 1; next }
        inf == 1 && /^---[[:space:]]*$/ { inf = 0; exit }
        inf == 1 {
            idx = index($0, ":")
            if (idx == 0) next
            key = substr($0, 1, idx - 1)
            val = substr($0, idx + 1)
            sub(/^[[:space:]]+/, "", key); sub(/[[:space:]]+$/, "", key)
            sub(/^[[:space:]]+/, "", val); sub(/[[:space:]]+$/, "", val)
            if (key == k) { print val; exit }
        }
    ' "$_file"
}

# _mh_promote_first_h1 <file> -> first "# Heading" text (sans leading "# ").
# Skips frontmatter. Empty if no H1 found.
_mh_promote_first_h1() {
    _file="$1"
    awk '
        BEGIN { inf = 0 }
        NR == 1 && /^---[[:space:]]*$/ { inf = 1; next }
        inf == 1 && /^---[[:space:]]*$/ { inf = 0; next }
        inf == 1 { next }
        /^#[[:space:]]+/ {
            sub(/^#[[:space:]]+/, "", $0)
            sub(/[[:space:]]+$/, "", $0)
            print
            exit
        }
    ' "$_file"
}

# _mh_promote_summary <file> -> summary body for distilled. Prefers the
# "## Generalizable rule" section (highest signal), else first paragraph
# after the first H1. Capped at ~1200 chars.
_mh_promote_summary() {
    _file="$1"
    _gr="$(awk '
        BEGIN { take = 0 }
        /^##[[:space:]]+[Gg]eneralizable [Rr]ule[[:space:]]*$/ { take = 1; next }
        take == 1 && /^##[[:space:]]/ { exit }
        take == 1 { print }
    ' "$_file")"
    if [ -n "$(printf '%s' "$_gr" | tr -d '[:space:]')" ]; then
        printf '%s' "$_gr" | head -c 1200
        return 0
    fi
    awk '
        BEGIN { inf = 0; past_h1 = 0; in_para = 0 }
        NR == 1 && /^---[[:space:]]*$/ { inf = 1; next }
        inf == 1 && /^---[[:space:]]*$/ { inf = 0; next }
        inf == 1 { next }
        past_h1 == 0 && /^#[[:space:]]+/ { past_h1 = 1; next }
        past_h1 == 1 {
            if (/^##[[:space:]]/) next
            if (/^[[:space:]]*$/) {
                if (in_para == 1) exit
                next
            }
            in_para = 1
            print
        }
    ' "$_file" | head -c 1200
}

# _mh_promote_infer_target <file> -> distilled basename. Uses frontmatter
# 'kind:' field, else patterns.md.
_mh_promote_infer_target() {
    _file="$1"
    _kind="$(_mh_promote_extract_frontmatter "$_file" kind)"
    case "$_kind" in
        win|wins)               printf 'wins.md' ;;
        mistake|mistakes)       printf 'mistakes.md' ;;
        cross-agent|insight|cross-agent-insight|cross-agent-insights)
                                printf 'cross-agent-insights.md' ;;
        pattern|patterns|"")    printf 'patterns.md' ;;
        *)                      printf '%s.md' "$_kind" ;;
    esac
}

mh_promote() {
    _mh_require_install

    _raw_arg=""
    _into=""
    _title_override=""
    _dry=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --into)
                shift
                [ $# -gt 0 ] || _mh_die "--into needs a value"
                _into="$1"; shift ;;
            --into=*)
                _into="${1#--into=}"; shift ;;
            --title)
                shift
                [ $# -gt 0 ] || _mh_die "--title needs a value"
                _title_override="$1"; shift ;;
            --title=*)
                _title_override="${1#--title=}"; shift ;;
            --dry-run|-n)
                _dry=1; shift ;;
            -h|--help)
                printf 'Usage: memory-hive promote <raw-file> [--into <name>] [--title <text>] [--dry-run]\n'
                return 0 ;;
            -*)
                _mh_die "Unknown flag: $1" ;;
            *)
                if [ -z "$_raw_arg" ]; then
                    _raw_arg="$1"
                else
                    _mh_die "Unexpected argument: $1"
                fi
                shift ;;
        esac
    done

    [ -n "$_raw_arg" ] || _mh_die "Usage: memory-hive promote <raw-file> [--into <name>] [--title <text>] [--dry-run]"

    # Resolve to an absolute path. Try as-given, then a few sensible roots.
    _raw_abs=""
    for _candidate in \
        "$_raw_arg" \
        "$INSTALL_DIR/$_raw_arg" \
        "$HIVE_DIR/$_raw_arg" \
        "$HIVE_DIR/learnings/raw/$_raw_arg"; do
        if [ -f "$_candidate" ]; then
            _raw_abs="$_candidate"
            break
        fi
    done
    [ -n "$_raw_abs" ] || _mh_die "Raw file not found: $_raw_arg"

    # Canonicalize via cd/pwd (portable; macOS has no `readlink -f`).
    _raw_dir="$(cd "$(dirname "$_raw_abs")" 2>/dev/null && pwd)"
    [ -n "$_raw_dir" ] || _mh_die "Could not resolve directory of $_raw_abs"
    _raw_abs="$_raw_dir/$(basename "$_raw_abs")"

    _raw_root="$HIVE_DIR/learnings/raw"
    case "$_raw_abs" in
        "$_raw_root"/*) ;;
        *) _mh_die "Refuses to promote from outside $_raw_root (got $_raw_abs)" ;;
    esac

    _fm_date="$(_mh_promote_extract_frontmatter "$_raw_abs" date)"
    _fm_agent="$(_mh_promote_extract_frontmatter "$_raw_abs" agent)"
    if [ -z "$_fm_date" ] || [ -z "$_fm_agent" ]; then
        printf 'ERROR: %s is missing required frontmatter (need date: and agent:).\n' "$_raw_abs" >&2
        printf '       See templates/memory-entry.md for the canonical format.\n' >&2
        exit 1
    fi
    _fm_context="$(_mh_promote_extract_frontmatter "$_raw_abs" context)"

    if [ -n "$_title_override" ]; then
        _title="$_title_override"
    else
        _title="$(_mh_promote_first_h1 "$_raw_abs")"
        if [ -z "$_title" ]; then
            _bn="$(basename "$_raw_abs" .md)"
            _title="$(printf '%s' "$_bn" | sed 's/^[0-9-]*//' | tr '-' ' ')"
            [ -n "$_title" ] || _title="$_bn"
        fi
    fi

    if [ -z "$_into" ]; then
        _into="$(_mh_promote_infer_target "$_raw_abs")"
    fi
    _into="$(basename "$_into")"
    case "$_into" in
        *.md) ;;
        *) _into="$_into.md" ;;
    esac
    _distilled_dir="$HIVE_DIR/learnings/distilled"
    _distilled_abs="$_distilled_dir/$_into"

    _raw_rel_to_hive="${_raw_abs#"$HIVE_DIR/"}"
    _backlink="../${_raw_rel_to_hive#learnings/}"

    _summary="$(_mh_promote_summary "$_raw_abs")"
    [ -n "$_summary" ] || _summary="_(no summary extracted; see source for full content)_"

    _today="$(date -u +%Y-%m-%d 2>/dev/null || printf 'unknown-date')"

    _section_tmp="$(mktemp -t mh-promote-section.XXXXXX)"
    {
        printf '\n## %s\n\n' "$_title"
        printf -- '- **Date promoted:** %s\n' "$_today"
        printf -- '- **Source:** [%s](%s)\n' "$_raw_rel_to_hive" "$_backlink"
        printf -- '- **Contributing agent:** %s\n' "$_fm_agent"
        printf -- '- **Original date:** %s\n' "$_fm_date"
        if [ -n "$_fm_context" ]; then
            printf -- '- **Context:** %s\n' "$_fm_context"
        fi
        printf '\n%s\n' "$_summary"
    } > "$_section_tmp"

    _decision_tmp="$(mktemp -t mh-promote-decision.XXXXXX)"
    {
        printf '\n### %s -- Promoted `%s` -> `learnings/distilled/%s`\n' \
            "$_today" "$_raw_rel_to_hive" "$_into"
        printf -- '- **Decision:** Append summary + backlink to %s.\n' "$_into"
        printf -- '- **Reasoning:** Promoted via `memory-hive promote`; raw entry retained as source of truth.\n'
        printf -- '- **Agents involved:** %s\n' "$_fm_agent"
        printf -- '- **Outcome:** Distilled section "%s" written; raw file left in place.\n' "$_title"
    } > "$_decision_tmp"

    if [ "$_dry" -eq 1 ]; then
        printf '[dry-run] Would append to %s:\n' "$_distilled_abs"
        cat "$_section_tmp"
        printf '\n[dry-run] Would append to %s/curator/DECISIONS.md:\n' "$HIVE_DIR"
        cat "$_decision_tmp"
        printf '\n[dry-run] No files written.\n'
        rm -f "$_section_tmp" "$_decision_tmp"
        return 0
    fi

    mkdir -p "$_distilled_dir" || _mh_die "Could not create $_distilled_dir"
    if [ ! -f "$_distilled_abs" ]; then
        _stem="$(basename "$_into" .md)"
        _h1="$(printf '%s' "$_stem" | tr '-' ' ' | awk '{ for (i=1;i<=NF;i++) $i = toupper(substr($i,1,1)) tolower(substr($i,2)); print }')"
        {
            printf '# %s\n\n' "$_h1"
            printf 'Curated learnings promoted from `learnings/raw/`. Each section cites\n'
            printf 'its source raw file; raw is the source of truth, distilled is the\n'
            printf 'reference index. Append-only -- entries are never edited in place.\n'
        } > "$_distilled_abs" || _mh_die "Could not create $_distilled_abs"
    fi
    cat "$_section_tmp" >> "$_distilled_abs" || _mh_die "Could not append to $_distilled_abs"

    _curator_dir="$HIVE_DIR/curator"
    _decisions_file="$_curator_dir/DECISIONS.md"
    mkdir -p "$_curator_dir" || _mh_die "Could not create $_curator_dir"
    if [ ! -f "$_decisions_file" ]; then
        {
            printf '# Decisions\n\n'
            printf 'Audit trail of every curation decision made by the curator.\n\n'
            printf -- '---\n'
        } > "$_decisions_file" || _mh_die "Could not create $_decisions_file"
    fi
    cat "$_decision_tmp" >> "$_decisions_file" || _mh_die "Could not append to $_decisions_file"

    rm -f "$_section_tmp" "$_decision_tmp"

    _mh_register_quiet

    printf 'Promoted:\n'
    printf '  source:   %s\n' "$_raw_rel_to_hive"
    printf '  target:   learnings/distilled/%s\n' "$_into"
    printf '  title:    %s\n' "$_title"
    printf '  decision: curator/DECISIONS.md\n'
    printf '\n--- appended to %s ---\n' "$_into"
    printf '\n## %s\n\n' "$_title"
    printf -- '- **Date promoted:** %s\n' "$_today"
    printf -- '- **Source:** [%s](%s)\n' "$_raw_rel_to_hive" "$_backlink"
    printf -- '- **Contributing agent:** %s\n' "$_fm_agent"
    printf -- '- **Original date:** %s\n' "$_fm_date"
    if [ -n "$_fm_context" ]; then
        printf -- '- **Context:** %s\n' "$_fm_context"
    fi
    printf '\n%s\n' "$_summary"
}

# --- tagging -----------------------------------------------------------------
#
# Lightweight topical tagging for learning files. Tags live in YAML-style
# frontmatter under the existing `date:`/`agent:` keys, comma-separated and
# sorted alphabetically for determinism. The point: let topical clusters
# (e.g. "testing", "parallel") emerge from the data so the curator can
# spin up new distilled/<topic>.md files without manual hunting.

# _mh_validate_tag <tag> → 0 if valid, 1 with stderr message if not.
# Rules: lowercase, [a-z0-9-], 2-24 chars, no leading/trailing dash, no run.
# Uses LC_ALL=C + grep so the character classes behave identically across
# platforms (macOS bash 3.2's `case` glob has surprised us at least once).
_mh_validate_tag() {
    _t="$1"
    if [ -z "$_t" ]; then
        printf 'ERROR: empty tag\n' >&2
        return 1
    fi
    _len=$(printf '%s' "$_t" | LC_ALL=C wc -c | tr -d ' ')
    if [ "$_len" -lt 2 ] || [ "$_len" -gt 24 ]; then
        printf 'ERROR: tag "%s" must be 2-24 chars (got %s)\n' "$_t" "$_len" >&2
        return 1
    fi
    # Whole-string match against the strict character set. grep -E with an
    # anchored alternation gives us platform-independent semantics; case-glob
    # `[!a-z0-9-]` was observed to silently accept "Bad" on the macOS CI
    # runner even though it rejects locally on the same OS.
    if ! printf '%s' "$_t" | LC_ALL=C grep -Eq '^[a-z0-9-]+$'; then
        printf 'ERROR: tag "%s" must be lowercase a-z, 0-9, or dash\n' "$_t" >&2
        return 1
    fi
    case "$_t" in
        -*|*-) printf 'ERROR: tag "%s" cannot start or end with a dash\n' "$_t" >&2; return 1 ;;
        *--*) printf 'ERROR: tag "%s" cannot contain consecutive dashes\n' "$_t" >&2; return 1 ;;
    esac
    return 0
}

# _mh_extract_tags <file> → prints comma-separated tag list from frontmatter,
# or empty if no tags: line. Only reads inside the first `---`/`---` fence.
_mh_extract_tags() {
    awk '
        BEGIN { fence = 0 }
        NR == 1 && /^---[[:space:]]*$/ { fence = 1; next }
        fence == 1 && /^---[[:space:]]*$/ { exit }
        fence == 1 && /^tags:[[:space:]]*/ {
            line = $0
            sub(/^tags:[[:space:]]*/, "", line)
            print line
            exit
        }
    ' "$1"
}

# _mh_has_frontmatter <file> → 0 if file starts with `---` fence, 1 otherwise.
_mh_has_frontmatter() {
    [ -f "$1" ] || return 1
    awk 'NR == 1 { if ($0 ~ /^---[[:space:]]*$/) exit 0; else exit 1 }' "$1"
}

# _mh_normalize_tags <comma-list> → newline-separated, trimmed, deduped, sorted.
# Empty entries dropped. Used to merge new + existing tag sets.
_mh_normalize_tags() {
    printf '%s' "$1" \
        | tr ',' '\n' \
        | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' \
        | awk 'NF > 0' \
        | sort -u
}

mh_tag() {
    _mh_require_install
    _file="$1"
    shift || true
    if [ -z "$_file" ] || [ $# -eq 0 ]; then
        _mh_die "Usage: memory-hive tag <file> <tag1> [tag2 ...]"
    fi
    if [ ! -f "$_file" ]; then
        _mh_die "File not found: $_file"
    fi
    case "$_file" in
        *.md|*.markdown) ;;
        *) _mh_die "Not a markdown file: $_file" ;;
    esac
    if ! _mh_has_frontmatter "$_file"; then
        printf 'ERROR: %s has no YAML frontmatter (must start with `---`).\n' "$_file" >&2
        printf 'Tip: add a frontmatter block manually, or run `memory-hive lint` once it exists.\n' >&2
        exit 1
    fi

    # Validate every input tag before touching the file.
    for _t in "$@"; do
        _mh_validate_tag "$_t" || exit 1
    done

    _existing="$(_mh_extract_tags "$_file")"
    _before="$_existing"
    [ -n "$_before" ] || _before='(none)'

    # Merge: existing + new args, normalized.
    _merged_input="$_existing"
    for _t in "$@"; do
        if [ -n "$_merged_input" ]; then
            _merged_input="$_merged_input,$_t"
        else
            _merged_input="$_t"
        fi
    done
    _merged="$(_mh_normalize_tags "$_merged_input")"
    # Re-join with ", " in sorted order.
    _new_line="$(printf '%s' "$_merged" | tr '\n' ',' | sed -e 's/,$//' -e 's/,/, /g')"

    # Rewrite the frontmatter:
    #   - if a `tags:` line exists, replace it
    #   - else insert before `agent:` (preferred), else after `date:`,
    #     else append before the closing `---`.
    _tmp="$_file.mhtag.$$"
    awk -v newtags="$_new_line" '
        BEGIN { fence = 0; in_fm = 0; replaced = 0; inserted = 0; saw_date = 0 }
        {
            if (NR == 1 && $0 ~ /^---[[:space:]]*$/) {
                print
                in_fm = 1
                next
            }
            if (in_fm == 1 && $0 ~ /^---[[:space:]]*$/) {
                # Closing fence — insert here if we never managed to.
                if (replaced == 0 && inserted == 0) {
                    print "tags: " newtags
                    inserted = 1
                }
                print
                in_fm = 2
                next
            }
            if (in_fm == 1) {
                if ($0 ~ /^tags:[[:space:]]*/) {
                    print "tags: " newtags
                    replaced = 1
                    next
                }
                if ($0 ~ /^agent:[[:space:]]*/ && replaced == 0 && inserted == 0) {
                    # Insert tags between date: and agent: for canonical order.
                    print "tags: " newtags
                    inserted = 1
                    print
                    next
                }
                print
                next
            }
            print
        }
    ' "$_file" > "$_tmp" || { rm -f "$_tmp"; _mh_die "Failed to rewrite $_file"; }
    mv "$_tmp" "$_file" || { rm -f "$_tmp"; _mh_die "Failed to write $_file"; }

    printf 'tags before: %s\n' "$_before"
    printf 'tags after:  %s\n' "$_new_line"
}

# _mh_tag_files: scan all .md files under the hive that have a `tags:` line in
# their frontmatter. Emit `tag<TAB>file` records, one per (tag, file) pair.
# Honors $MH_FILTER_AGENT if set (limits to that agent's silo + raw learnings).
_mh_tag_files() {
    [ -d "$HIVE_DIR" ] || return 0
    find "$HIVE_DIR" -type f -name '*.md' \
        ! -path "*/.git/*" \
        ! -path "*/_archived/*" \
        ! -name "*.upstream" \
        2>/dev/null | while IFS= read -r _f; do
        if [ -n "${MH_FILTER_AGENT:-}" ]; then
            _rel="${_f#"$HIVE_DIR"/}"
            case "$_rel" in
                agents/"$MH_FILTER_AGENT"/*) ;;
                learnings/raw/"$MH_FILTER_AGENT"-*.md) ;;
                learnings/raw/"$MH_FILTER_AGENT"/*) ;;
                *) continue ;;
            esac
        fi
        _line="$(_mh_extract_tags "$_f")"
        [ -n "$_line" ] || continue
        printf '%s' "$_line" | tr ',' '\n' \
            | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' \
            | awk -v f="$_f" 'NF > 0 { print $0 "\t" f }'
    done
}

mh_tags() {
    _mh_require_install
    _filter_agent=""
    _filter_tag=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --agent)
                shift
                [ $# -gt 0 ] || _mh_die "--agent needs a value"
                _filter_agent="$1"; shift ;;
            --agent=*) _filter_agent="${1#--agent=}"; shift ;;
            --tag)
                shift
                [ $# -gt 0 ] || _mh_die "--tag needs a value"
                _filter_tag="$1"; shift ;;
            --tag=*) _filter_tag="${1#--tag=}"; shift ;;
            -h|--help)
                printf 'Usage: memory-hive tags [--agent <name>] [--tag <name>]\n'
                return 0 ;;
            *) _mh_die "Unknown argument: $1" ;;
        esac
    done

    MH_FILTER_AGENT="$_filter_agent"
    export MH_FILTER_AGENT

    _records="$(_mh_tag_files)"

    if [ -z "$_records" ]; then
        if [ -n "$_filter_agent" ]; then
            printf '(no tagged learning files for agent "%s")\n' "$_filter_agent"
        else
            printf '(no tagged learning files yet — try `memory-hive tag <file> <tag>`)\n'
        fi
        return 0
    fi

    if [ -n "$_filter_tag" ]; then
        # List files using this tag.
        _matches="$(printf '%s\n' "$_records" \
            | awk -F'	' -v want="$_filter_tag" '$1 == want { print $2 }' \
            | sort -u)"
        if [ -z "$_matches" ]; then
            printf '(no files use tag "%s")\n' "$_filter_tag"
            return 0
        fi
        # Build the output as one string so a downstream `| grep -q` exiting
        # early can't EPIPE us mid-loop. macOS bash-as-sh under `set -e`
        # was tripping on broken-pipe in a piped while-loop.
        _out="$(printf 'Files tagged "%s":\n' "$_filter_tag"
            printf '%s\n' "$_matches" | while IFS= read -r _f; do
                _rel="${_f#"$HIVE_DIR"/}"
                printf '  %s\n' "$_rel"
            done)"
        printf '%s\n' "$_out"
        return 0
    fi

    # Default: tag → count, sorted desc. Same EPIPE-safe pattern as above —
    # accumulate then print once.
    _header="Tags in hive"
    [ -n "$_filter_agent" ] && _header="$_header (agent=$_filter_agent)"
    _body="$(printf '%s\n' "$_records" \
        | awk -F'	' '{ print $1 }' \
        | sort | uniq -c | sort -rn \
        | awk '{
            count = $1
            $1 = ""
            sub(/^ /, "")
            printf "  %4d  %s\n", count, $0
        }')"
    printf '%s:\n%s\n' "$_header" "$_body"
}

# mh_stale — list raw learnings older than N days with no curator decision.
# Flags:
#   --days N          window in days (default 7, env MEMORY_HIVE_STALE_DAYS)
#   --agent <name>    only that agent's raw subdir
#   --count           print just the integer count (scriptable)
#   -h | --help       usage
mh_stale() {
    _mh_require_install
    _days="${MEMORY_HIVE_STALE_DAYS:-7}"
    _agent=""
    _count_only=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --days)
                shift
                [ $# -gt 0 ] || _mh_die "--days requires a number"
                case "$1" in
                    *[!0-9]*|"") _mh_die "--days must be a positive integer (got: $1)" ;;
                esac
                _days="$1"
                ;;
            --days=*)
                _days="${1#--days=}"
                case "$_days" in
                    *[!0-9]*|"") _mh_die "--days must be a positive integer (got: $_days)" ;;
                esac
                ;;
            --agent)
                shift
                [ $# -gt 0 ] || _mh_die "--agent requires a name"
                _agent="$1"
                ;;
            --agent=*) _agent="${1#--agent=}" ;;
            --count|-c) _count_only=1 ;;
            -h|--help)
                cat <<EOF
Usage: memory-hive stale [--days N] [--agent <name>] [--count]

  List raw learnings older than N days (default 7) that have not been
  referenced in curator/DECISIONS.md. Sorted by age, oldest first.
  Same data the doctor's stale section uses.

  --days N          window in days (env: MEMORY_HIVE_STALE_DAYS)
  --agent <name>    filter to one agent's raw subdir
  --count           print just the count (for scripts / hooks)
EOF
                return 0
                ;;
            *) _mh_die "Unknown flag: $1 (try \`memory-hive stale --help\`)" ;;
        esac
        shift
    done

    _stale_tmp="${TMPDIR:-/tmp}/mh-stale-cli.$$"
    _mh_stale_raw_files "$_days" "$_agent" > "$_stale_tmp" 2>/dev/null || : > "$_stale_tmp"
    _n="$(awk 'END { print NR }' "$_stale_tmp" 2>/dev/null)"
    [ -n "$_n" ] || _n=0

    if [ "$_count_only" -eq 1 ]; then
        printf '%s\n' "$_n"
        rm -f "$_stale_tmp"
        return 0
    fi

    if [ "$_n" -eq 0 ]; then
        if [ -n "$_agent" ]; then
            printf 'No stale raw learnings for agent %s (>%s days, no decision).\n' \
                "$_agent" "$_days"
        else
            printf 'No stale raw learnings (>%s days, no decision).\n' "$_days"
        fi
        rm -f "$_stale_tmp"
        return 0
    fi

    if [ -n "$_agent" ]; then
        printf 'Stale raw learnings for %s (>%s days, no DECISIONS.md backlink): %s\n\n' \
            "$_agent" "$_days" "$_n"
    else
        printf 'Stale raw learnings (>%s days, no DECISIONS.md backlink): %s\n\n' \
            "$_days" "$_n"
    fi
    printf '  %4s  %-18s  %s\n' "AGE" "AGENT" "PATH"
    while IFS='	' read -r _age _ag _path; do
        [ -n "$_age" ] || continue
        _rel="${_path#"$HIVE_DIR"/}"
        printf '  %3sd  %-18s  %s\n' "$_age" "$_ag" "$_rel"
    done < "$_stale_tmp"
    rm -f "$_stale_tmp"
}

# --- checkpoints + diff ------------------------------------------------------
#
# Checkpoints are named, empty marker files under $HIVE_DIR/.checkpoints/.
# Their mtime is the reference timestamp. We deliberately re-use the same
# pattern install.sh uses for $HIVE_DIR/.baseline-installed so the diff
# code can treat the install baseline as just another checkpoint.

CHECKPOINTS_DIR_REL=".checkpoints"

# _mh_checkpoints_dir → prints absolute path to the checkpoint store.
_mh_checkpoints_dir() {
    printf '%s/%s' "$HIVE_DIR" "$CHECKPOINTS_DIR_REL"
}

# _mh_default_checkpoint_name → "checkpoint-YYYY-MM-DD-HHMMSS" in local time.
_mh_default_checkpoint_name() {
    date '+checkpoint-%Y-%m-%d-%H%M%S' 2>/dev/null \
        || printf 'checkpoint-%s' "$(date +%s)"
}

# _mh_validate_checkpoint_name <name> → 0 if safe (no /, no leading dot, non-empty).
_mh_validate_checkpoint_name() {
    _cn="$1"
    [ -n "$_cn" ] || return 1
    case "$_cn" in
        */*|.*) return 1 ;;
    esac
    return 0
}

# _mh_iso_time <epoch> → "YYYY-MM-DD HH:MM:SS" in local time.
_mh_iso_time() {
    _e="$1"
    date -d "@$_e" '+%Y-%m-%d %H:%M:%S' 2>/dev/null \
        || date -r "$_e" '+%Y-%m-%d %H:%M:%S' 2>/dev/null \
        || printf '????-??-?? ??:??:??'
}

# _mh_list_checkpoint_files → prints absolute paths of all *.marker files,
# newest mtime first. Empty if the dir is missing.
_mh_list_checkpoint_files() {
    _cd="$(_mh_checkpoints_dir)"
    [ -d "$_cd" ] || return 0
    # Build "epoch<TAB>path" rows so we can sort by epoch portably.
    for _m in "$_cd"/*.marker; do
        [ -f "$_m" ] || continue
        _e="$(_mh_mtime_epoch "$_m")"
        [ -n "$_e" ] || continue
        printf '%s\t%s\n' "$_e" "$_m"
    done | sort -nr | awk -F'\t' '{print $2}'
}

# _mh_resolve_checkpoint <name> → prints absolute path of the matching marker
# file, or empty + nonzero if no/ambiguous match. Matches first by exact
# basename, then by basename minus the .marker suffix.
_mh_resolve_checkpoint() {
    _q="$1"
    _cd="$(_mh_checkpoints_dir)"
    [ -d "$_cd" ] || return 1
    _exact="$_cd/$_q.marker"
    if [ -f "$_exact" ]; then
        printf '%s' "$_exact"
        return 0
    fi
    _exact2="$_cd/$_q"
    if [ -f "$_exact2" ]; then
        printf '%s' "$_exact2"
        return 0
    fi
    # Substring fallback (only useful for the diff verb's --since).
    _hits=""
    _count=0
    for _m in "$_cd"/*.marker; do
        [ -f "$_m" ] || continue
        _bn="$(basename "$_m" .marker)"
        case "$_bn" in
            *"$_q"*)
                _hits="$_hits $_m"
                _count=$((_count + 1))
                ;;
        esac
    done
    if [ "$_count" -eq 1 ]; then
        # Strip leading space.
        printf '%s' "${_hits# }"
        return 0
    fi
    if [ "$_count" -gt 1 ]; then
        # Ambiguous — caller decides how to surface this. Emit names on
        # stderr and return nonzero so callers know to abort.
        printf 'Ambiguous checkpoint name "%s". Matches:\n' "$_q" >&2
        for _m in $_hits; do
            printf '  %s\n' "$(basename "$_m" .marker)" >&2
        done
        return 2
    fi
    return 1
}

# _mh_parse_ymd_to_epoch <YYYY-MM-DD> → epoch of midnight (local time), or
# empty + nonzero if the input doesn't parse.
_mh_parse_ymd_to_epoch() {
    _d="$1"
    case "$_d" in
        [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]) ;;
        *) return 1 ;;
    esac
    # GNU date first, then BSD date.
    _e="$(date -d "$_d 00:00:00" +%s 2>/dev/null)"
    if [ -z "$_e" ]; then
        _e="$(date -j -f '%Y-%m-%d %H:%M:%S' "$_d 00:00:00" +%s 2>/dev/null)"
    fi
    [ -n "$_e" ] || return 1
    printf '%s' "$_e"
}

mh_checkpoint() {
    _mh_require_install
    _name=""
    _list=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --name)
                shift
                [ $# -gt 0 ] || _mh_die "--name needs a value"
                _name="$1"
                shift
                ;;
            --name=*)
                _name="${1#--name=}"
                shift
                ;;
            --list|-l)
                _list=1
                shift
                ;;
            -h|--help)
                printf 'Usage: memory-hive checkpoint [--name <name>] | --list\n'
                return 0
                ;;
            *)
                _mh_die "Unknown argument: $1"
                ;;
        esac
    done

    _cd="$(_mh_checkpoints_dir)"

    if [ "$_list" -eq 1 ]; then
        if [ ! -d "$_cd" ]; then
            printf '(no checkpoints yet — create one with `memory-hive checkpoint`)\n'
            return 0
        fi
        _any=0
        _mh_list_checkpoint_files | while IFS= read -r _m; do
            [ -n "$_m" ] || continue
            _bn="$(basename "$_m" .marker)"
            _e="$(_mh_mtime_epoch "$_m")"
            printf '  %-40s %s\n' "$_bn" "$(_mh_iso_time "$_e")"
            _any=1
        done
        # The subshell-in-pipe means $_any doesn't escape; check on disk instead.
        if [ -z "$(_mh_list_checkpoint_files)" ]; then
            printf '(no checkpoints yet — create one with `memory-hive checkpoint`)\n'
        fi
        return 0
    fi

    [ -n "$_name" ] || _name="$(_mh_default_checkpoint_name)"
    _mh_validate_checkpoint_name "$_name" \
        || _mh_die "Invalid checkpoint name: '$_name' (no slashes, no leading dot)."

    mkdir -p "$_cd" || _mh_die "Could not create $_cd"
    _marker="$_cd/$_name.marker"
    if [ -f "$_marker" ]; then
        _mh_die "Checkpoint already exists: $_name (delete it first or pick a new name)"
    fi
    : > "$_marker" || _mh_die "Could not write $_marker"
    # touch sets mtime = now even if the file already existed; keep it
    # explicit so the mtime is unambiguous.
    touch "$_marker" 2>/dev/null || true
    _e="$(_mh_mtime_epoch "$_marker")"
    [ -n "$_e" ] || _e="$(date +%s)"
    printf 'Checkpoint saved: %s at %s\n' "$_name" "$(_mh_iso_time "$_e")"
}

mh_diff() {
    _mh_require_install
    _since=""
    _verbose=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --since)
                shift
                [ $# -gt 0 ] || _mh_die "--since needs a value"
                _since="$1"
                shift
                ;;
            --since=*)
                _since="${1#--since=}"
                shift
                ;;
            --verbose|-v)
                _verbose=1
                shift
                ;;
            -h|--help)
                printf 'Usage: memory-hive diff [--since <checkpoint|YYYY-MM-DD>] [--verbose]\n'
                return 0
                ;;
            *)
                _mh_die "Unknown argument: $1"
                ;;
        esac
    done

    # --- resolve the reference point --------------------------------------
    _ref_label=""        # human-readable "<name> (timestamp)" string
    _ref_mtime=""        # epoch — files with mtime > this are "changed"
    _ref_marker=""       # absolute path used with `find -newer` (preferred)

    _baseline_file="$HIVE_DIR/.baseline-installed"

    if [ -n "$_since" ]; then
        # YYYY-MM-DD wins over a coincidentally same-named checkpoint —
        # the date format is unambiguous and a checkpoint-name-of-a-date
        # would be unusual.
        # `|| true` so set -e doesn't abort when the input isn't a date.
        _maybe_epoch="$(_mh_parse_ymd_to_epoch "$_since" 2>/dev/null || true)"
        if [ -n "$_maybe_epoch" ]; then
            _ref_mtime="$_maybe_epoch"
            _ref_label="$_since (00:00:00)"
            # We don't have a real file at that mtime, so we synthesize one
            # in /tmp for the find -newer call.
            _ref_marker="$(mktemp -t mh-diff.XXXXXX)"
            # Portable touch -t: GNU accepts -d "@epoch", BSD accepts -t [[CC]YY]MMDDhhmm[.ss].
            if ! touch -d "@$_ref_mtime" "$_ref_marker" 2>/dev/null; then
                _stamp="$(date -r "$_ref_mtime" '+%Y%m%d%H%M.%S' 2>/dev/null \
                    || date -d "@$_ref_mtime" '+%Y%m%d%H%M.%S' 2>/dev/null)"
                [ -n "$_stamp" ] && touch -t "$_stamp" "$_ref_marker" 2>/dev/null || true
            fi
        else
            # Try to resolve as a checkpoint name. We deliberately swallow
            # the exit code into _rc so set -e doesn't abort on the
            # not-found / ambiguous paths.
            set +e
            _resolved="$(_mh_resolve_checkpoint "$_since" 2>/tmp/mh-diff-resolve.$$.err)"
            _rc=$?
            set -e
            # Surface ambiguity output if any.
            if [ -s /tmp/mh-diff-resolve.$$.err ]; then
                cat /tmp/mh-diff-resolve.$$.err >&2
            fi
            rm -f /tmp/mh-diff-resolve.$$.err
            if [ "$_rc" -eq 2 ]; then
                # Ambiguous — _mh_resolve_checkpoint already printed candidates.
                exit 1
            fi
            if [ "$_rc" -ne 0 ] || [ -z "$_resolved" ]; then
                _mh_die "No checkpoint or date matches '$_since'. Run \`memory-hive checkpoint --list\` to see available names."
            fi
            _ref_marker="$_resolved"
            _ref_mtime="$(_mh_mtime_epoch "$_ref_marker")"
            _ref_label="$(basename "$_ref_marker" .marker) ($(_mh_iso_time "$_ref_mtime"))"
        fi
    else
        # Default: newest checkpoint, falling back to baseline.
        _newest="$(_mh_list_checkpoint_files | head -n 1)"
        if [ -n "$_newest" ]; then
            _ref_marker="$_newest"
            _ref_mtime="$(_mh_mtime_epoch "$_ref_marker")"
            _ref_label="$(basename "$_ref_marker" .marker) ($(_mh_iso_time "$_ref_mtime"))"
        elif [ -f "$_baseline_file" ]; then
            _ref_marker="$_baseline_file"
            _ref_mtime="$(_mh_mtime_epoch "$_ref_marker")"
            _ref_label="install baseline ($(_mh_iso_time "$_ref_mtime"))"
        else
            _mh_die "No checkpoints and no install baseline found. Create a checkpoint with \`memory-hive checkpoint\`."
        fi
    fi

    [ -n "$_ref_mtime" ] || _mh_die "Could not determine reference mtime."

    # --- collect changed files --------------------------------------------
    # Primary diff is `find -newer <marker>` (POSIX). We then classify
    # each path so we can group by kind/agent.
    _new_list="$(mktemp -t mh-diff-new.XXXXXX)"
    _mod_list="$(mktemp -t mh-diff-mod.XXXXXX)"
    _all_count=0
    _agent_tally=""

    # find ! -path tricks to skip the same noise mh_stats skips, plus the
    # checkpoints dir itself (otherwise creating a checkpoint shows up as
    # a "write").
    find "$HIVE_DIR" -type f -newer "$_ref_marker" \
        ! -name '*.upstream' \
        ! -name '*.local' \
        ! -name '.DS_Store' \
        ! -path '*/.git/*' \
        ! -path "$HIVE_DIR/$CHECKPOINTS_DIR_REL/*" \
        ! -path "$_baseline_file" \
        2>/dev/null \
    | while IFS= read -r _f; do
        [ -f "$_f" ] || continue
        _cls="$(_mh_classify "$_f")"
        # Unclassified files are noise (e.g. .git internals); skip.
        [ -n "$_cls" ] || continue
        _rel="${_f#"$HIVE_DIR"/}"
        # New-vs-modified heuristic. POSIX only guarantees mtime/atime/ctime
        # (no birth time), so this is best-effort:
        #   1. If the filesystem exposes birth time (macOS `stat -f %B`,
        #      Linux ext4 `stat -c %W`), and birth > ref_mtime → "new".
        #   2. Otherwise fall back to ctime: if ctime > ref_mtime AND
        #      ctime is within a small window of mtime, treat as "new"
        #      (a freshly created file has ctime ≈ mtime). If ctime is
        #      well after the file's earliest known timestamp, prefer
        #      "modified".
        #   3. Last resort: if we can't decide, mark "modified" — that
        #      message ("file changed after ref") is always true for
        #      anything `find -newer` returned.
        # Try birth time first (macOS APFS, Linux ext4 with statx).
        # Order matters: GNU stat (-c) on macOS would produce a usage
        # error to stderr but no output; BSD stat (-f %B) on Linux
        # interprets -f as filesystem-stat and emits a multi-line
        # human-readable format. Try GNU first, then BSD, and validate
        # the result is a positive integer before trusting it.
        _btime="$(stat -c %W "$_f" 2>/dev/null || stat -f %B "$_f" 2>/dev/null || printf '')"
        case "$_btime" in
            ''|0|-)                 _btime="" ;;
            *[!0-9]*)               _btime="" ;;  # non-numeric → garbage
        esac
        _is_new=0
        if [ -n "$_btime" ]; then
            # Real birth time is authoritative.
            [ "$_btime" -gt "$_ref_mtime" ] && _is_new=1
        else
            # Fallback: if ctime ≈ mtime AND ctime > ref, the file's
            # inode metadata was set ≈ when the content was last written
            # — characteristic of a fresh creation. An in-place append
            # bumps both, but on filesystems where ctime tracks "any
            # metadata change" the gap to mtime tends to be larger over
            # time. Imperfect; documented in the PR description.
            _mtime="$(_mh_mtime_epoch "$_f")"
            _ctime="$(stat -c %Z "$_f" 2>/dev/null || stat -f %c "$_f" 2>/dev/null || printf '')"
            case "$_ctime" in *[!0-9]*) _ctime="" ;; esac
            case "$_mtime" in *[!0-9]*) _mtime="" ;; esac
            if [ -n "$_ctime" ] && [ -n "$_mtime" ] \
                && [ "$_ctime" -gt "$_ref_mtime" ]; then
                _delta=$((_ctime - _mtime))
                [ "$_delta" -lt 0 ] && _delta=$(( -_delta ))
                [ "$_delta" -le 2 ] && _is_new=1
            fi
        fi
        if [ "$_is_new" -eq 1 ]; then
            printf '%s\t%s\n' "$_cls" "$_rel" >> "$_new_list"
        else
            printf '%s\t%s\n' "$_cls" "$_rel" >> "$_mod_list"
        fi
    done

    _new_n=0
    [ -s "$_new_list" ] && _new_n="$(wc -l < "$_new_list" | tr -d ' ')"
    _mod_n=0
    [ -s "$_mod_list" ] && _mod_n="$(wc -l < "$_mod_list" | tr -d ' ')"
    _all_count=$((_new_n + _mod_n))

    # --- render -----------------------------------------------------------
    printf '\nMemory Hive — diff since `%s`\n' "$_ref_label"
    printf '────────────────────────────────────────────────────────────────\n'

    if [ "$_all_count" -eq 0 ]; then
        printf '\nNo writes since reference.\n\n'
        rm -f "$_new_list" "$_mod_list"
        return 0
    fi

    if [ "$_new_n" -gt 0 ]; then
        printf '\nNew files (%s):\n' "$_new_n"
        sort "$_new_list" | while IFS=$(printf '\t') read -r _cls _rel; do
            if [ "$_verbose" -eq 1 ]; then
                printf '  %-30s %s\n' "$_cls" "$_rel"
            else
                printf '  %s\n' "$_rel"
            fi
        done
    fi

    if [ "$_mod_n" -gt 0 ]; then
        printf '\nModified (%s):\n' "$_mod_n"
        sort "$_mod_list" | while IFS=$(printf '\t') read -r _cls _rel; do
            if [ "$_verbose" -eq 1 ]; then
                printf '  %-30s %s\n' "$_cls" "$_rel"
            else
                printf '  %s\n' "$_rel"
            fi
        done
    fi

    # Agent summary — count distinct agents touched.
    _agents="$( { [ -s "$_new_list" ] && cat "$_new_list"; [ -s "$_mod_list" ] && cat "$_mod_list"; } \
        | awk -F'\t' '{ split($1, a, ":"); print a[1] }' \
        | sort -u )"
    _agent_n=0
    if [ -n "$_agents" ]; then
        _agent_n="$(printf '%s\n' "$_agents" | wc -l | tr -d ' ')"
    fi

    printf '\nSummary: %s write(s) across %s agent(s).\n' "$_all_count" "$_agent_n"
    printf 'Verify: find %s -type f -newer %s\n\n' "$HIVE_DIR" "$_ref_marker"

    rm -f "$_new_list" "$_mod_list"
    # If we synthesized a temp marker for a date-based --since, clean up.
    case "$_ref_marker" in
        /tmp/mh-diff.*|/var/folders/*/mh-diff.*) rm -f "$_ref_marker" ;;
    esac
    return 0
}


# --- dedup: detect near-duplicate raw learnings -----------------------------
#
# Problem: hive/learnings/raw/<agent>/*.md accumulates near-duplicates as
# multiple agents independently observe the same pattern. Without dedup the
# curator's queue grows linearly and signal thins.
#
# Approach (cheap, POSIX, non-destructive):
#   1. Walk hive/learnings/raw/<agent>/*.md
#   2. For each file extract a title -- first H1 heading, falling back to the
#      filename's slug (stripping a leading YYYY-MM-DD- date if present).
#   3. Normalize the title: lowercase, non-alphanumeric -> space, drop a small
#      stopword list, sort+dedupe the remaining tokens, rejoin with single
#      spaces. Sorting tokens means "retry backoff cap" and "cap retry backoff"
#      collapse to the same key.
#   4. Group files by normalized key. Any group with 2+ entries is a cluster.
#
# --strict adds a second pass: keep the cluster only if first-paragraph
# word-overlap with the cluster anchor is >= threshold (default 50%). Overlap
# is |A intersect B| / max(|A|, |B|) over significant tokens (post-stopword)
# in the first paragraph of each file.
#
# This verb never modifies raw learnings; it only reports.

# _mh_dedup_stopwords -- significant-word filter. Drop articles, prepositions,
# auxiliaries, and the most generic English glue. Kept short on purpose: the
# point is to collapse "the test isolation rule" and "test isolation rule"
# into the same key, not to do real NLP.
_mh_dedup_stopwords() {
    printf '%s\n' \
        a an the and or but if then else for of to in on at by with from \
        is are was were be been being am do does did done doing has have \
        had having i you he she it we they me him her us them my your his \
        its our their this that these those as so not no yes also only \
        very just than which who whom whose what when where why how \
        about into onto over under between through during after before \
        because while although though even still already once here there
}

# _mh_dedup_normalize <text> -> prints normalized title (sorted token list,
# space-separated, stopwords dropped). Empty input -> empty output.
_mh_dedup_normalize() {
    _txt="$1"
    [ -n "$_txt" ] || return 0
    _stop="$(_mh_dedup_stopwords | tr '\n' ' ')"
    printf '%s' "$_txt" \
        | tr '[:upper:]' '[:lower:]' \
        | tr -c 'a-z0-9' ' ' \
        | tr -s ' ' '\n' \
        | awk -v stop=" $_stop " '
            NF && length($0) > 1 {
                pat = " " $0 " "
                if (index(stop, pat) == 0) print $0
            }
        ' \
        | sort -u \
        | tr '\n' ' ' \
        | sed -e 's/ *$//' -e 's/^ *//'
}

# _mh_dedup_title <file> -> prints the file's title:
#   1. First H1 ("# foo") if present
#   2. Else: filename slug, with leading YYYY-MM-DD- stripped, dashes -> spaces
_mh_dedup_title() {
    _f="$1"
    _h1="$(awk '
        /^# / {
            line = $0
            sub(/^# +/, "", line)
            sub(/[[:space:]]+$/, "", line)
            if (line != "") { print line; exit }
        }
    ' "$_f" 2>/dev/null)"
    if [ -n "$_h1" ]; then
        printf '%s' "$_h1"
        return 0
    fi
    _base="$(basename "$_f" .md)"
    case "$_base" in
        [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*)
            _base="$(printf '%s' "$_base" | cut -c12-)"
            ;;
    esac
    printf '%s' "$_base" | tr '-_' '  '
}

# _mh_dedup_first_para <file> -> prints the first paragraph (lines after any
# YAML frontmatter and the first H1, up to the next blank line). Used by
# --strict.
_mh_dedup_first_para() {
    _f="$1"
    awk '
        BEGIN { fm = 0; saw_fm = 0; past_h1 = 0; in_para = 0 }
        NR == 1 && /^---$/ { fm = 1; saw_fm = 1; next }
        fm == 1 {
            if ($0 ~ /^---$/) { fm = 0 }
            next
        }
        /^# / && past_h1 == 0 { past_h1 = 1; next }
        past_h1 == 0 && saw_fm == 0 { past_h1 = 1 }
        past_h1 == 1 {
            if ($0 ~ /^[[:space:]]*$/) {
                if (in_para == 1) { exit }
                next
            }
            if ($0 ~ /^#/) { next }
            in_para = 1
            print
        }
    ' "$_f" 2>/dev/null
}

# _mh_dedup_tokens <text> -> prints one significant token per line (lowercased,
# stopwords dropped, deduped via sort -u). Used to compute set overlap.
_mh_dedup_tokens() {
    _txt="$1"
    [ -n "$_txt" ] || return 0
    _stop="$(_mh_dedup_stopwords | tr '\n' ' ')"
    printf '%s' "$_txt" \
        | tr '[:upper:]' '[:lower:]' \
        | tr -c 'a-z0-9' ' ' \
        | tr -s ' ' '\n' \
        | awk -v stop=" $_stop " '
            NF && length($0) > 1 {
                pat = " " $0 " "
                if (index(stop, pat) == 0) print $0
            }
        ' \
        | sort -u
}

# _mh_dedup_overlap_pct <file_a> <file_b> -> prints integer percentage 0..100
# of word-overlap on first-paragraph tokens. |A intersect B| / max(|A|,|B|).
# Empty paragraphs -> 0.
_mh_dedup_overlap_pct() {
    _fa="$1"; _fb="$2"
    _ta="$INSTALL_DIR/.dedup-a.$$"
    _tb="$INSTALL_DIR/.dedup-b.$$"
    _mh_dedup_tokens "$(_mh_dedup_first_para "$_fa")" > "$_ta" 2>/dev/null
    _mh_dedup_tokens "$(_mh_dedup_first_para "$_fb")" > "$_tb" 2>/dev/null
    _na=$(wc -l < "$_ta" 2>/dev/null | tr -d ' ')
    _nb=$(wc -l < "$_tb" 2>/dev/null | tr -d ' ')
    [ -z "$_na" ] && _na=0
    [ -z "$_nb" ] && _nb=0
    if [ "$_na" -eq 0 ] || [ "$_nb" -eq 0 ]; then
        rm -f "$_ta" "$_tb"
        printf '0'
        return 0
    fi
    _inter=$(comm -12 "$_ta" "$_tb" 2>/dev/null | wc -l | tr -d ' ')
    [ -z "$_inter" ] && _inter=0
    _denom=$_na
    [ "$_nb" -gt "$_denom" ] && _denom=$_nb
    rm -f "$_ta" "$_tb"
    [ "$_denom" -eq 0 ] && { printf '0'; return 0; }
    printf '%d' $((_inter * 100 / _denom))
}

mh_dedup() {
    _mh_require_install

    _across_agents=1
    _strict=0
    _threshold=50

    while [ $# -gt 0 ]; do
        case "$1" in
            --across-agents) _across_agents=1 ;;
            --per-agent)     _across_agents=0 ;;
            --strict)        _strict=1 ;;
            --threshold)
                shift
                [ $# -gt 0 ] || _mh_die "--threshold needs a value (0..100)"
                _threshold="$1"
                ;;
            --threshold=*)
                _threshold="${1#--threshold=}"
                ;;
            -h|--help)
                cat <<EOF
Usage: memory-hive dedup [--per-agent] [--strict] [--threshold N]
  --per-agent       Cluster within each agent's raw/ dir only.
                    Default is to cluster across all agents.
  --strict          Filter clusters by first-paragraph word-overlap.
  --threshold N     Strict overlap threshold, 0..100 (default 50).
Output is print-only; raw files are never modified.
EOF
                return 0
                ;;
            *) _mh_die "Unknown flag: $1 (try: memory-hive dedup --help)" ;;
        esac
        shift
    done

    case "$_threshold" in
        ''|*[!0-9]*) _mh_die "--threshold must be an integer 0..100" ;;
    esac
    if [ "$_threshold" -lt 0 ] || [ "$_threshold" -gt 100 ]; then
        _mh_die "--threshold must be an integer 0..100"
    fi

    _raw_root="$HIVE_DIR/learnings/raw"
    if [ ! -d "$_raw_root" ]; then
        printf 'No raw learnings directory at %s -- nothing to dedup.\n' "$_raw_root"
        return 0
    fi

    # Tuples file: each line is "scope|normkey TAB relpath TAB abspath".
    _tuples="$INSTALL_DIR/.dedup-tuples.$$"
    : > "$_tuples"

    _file_count=0
    for _agent_dir in "$_raw_root"/*; do
        [ -d "$_agent_dir" ] || continue
        _agent="$(basename "$_agent_dir")"
        for _f in "$_agent_dir"/*.md; do
            [ -f "$_f" ] || continue
            _file_count=$((_file_count + 1))
            _title="$(_mh_dedup_title "$_f")"
            _norm="$(_mh_dedup_normalize "$_title")"
            [ -n "$_norm" ] || continue
            if [ "$_across_agents" -eq 1 ]; then
                _scope="*"
            else
                _scope="$_agent"
            fi
            _rel="${_f#"$HIVE_DIR"/}"
            printf '%s\t%s\t%s\n' "$_scope|$_norm" "$_rel" "$_f" >> "$_tuples"
        done
    done

    if [ "$_file_count" -eq 0 ]; then
        rm -f "$_tuples"
        printf 'No raw learnings found under %s -- nothing to dedup.\n' "$_raw_root"
        return 0
    fi

    _sorted="$INSTALL_DIR/.dedup-sorted.$$"
    LC_ALL=C sort "$_tuples" > "$_sorted"
    rm -f "$_tuples"

    # Group adjacent tuples with the same key. For each group of >= 2 emit
    # a cluster record into $_clusters as:
    #   ===CLUSTER===
    #   <displayed normalized title>
    #   <relpath 1>
    #   <relpath 2>
    #   ...
    _clusters="$INSTALL_DIR/.dedup-clusters.$$"
    : > "$_clusters"

    _flush_cluster() {
        [ -n "$_cur_key" ] || return 0
        _count=$(printf '%s\n' "$_cur_files" | grep -c .)
        [ "$_count" -ge 2 ] || return 0

        if [ "$_strict" -eq 1 ]; then
            _kept_files=""
            _anchor=""
            _i=1
            _IFS_save="$IFS"
            IFS='
'
            for _line in $_cur_files; do
                _path_for_line="$(printf '%s\n' "$_cur_paths" | sed -n "${_i}p")"
                if [ -z "$_anchor" ]; then
                    _anchor="$_path_for_line"
                    _kept_files="$_line"
                else
                    _pct="$(_mh_dedup_overlap_pct "$_anchor" "$_path_for_line")"
                    if [ "$_pct" -ge "$_threshold" ]; then
                        if [ -z "$_kept_files" ]; then
                            _kept_files="$_line"
                        else
                            _kept_files="$_kept_files
$_line"
                        fi
                    fi
                fi
                _i=$((_i + 1))
            done
            IFS="$_IFS_save"
            _kept_count=$(printf '%s\n' "$_kept_files" | grep -c .)
            [ "$_kept_count" -ge 2 ] || return 0
            _cur_files="$_kept_files"
        fi

        _disp_key="${_cur_key#*|}"
        printf '%s\n' "===CLUSTER===" >> "$_clusters"
        printf '%s\n' "$_disp_key" >> "$_clusters"
        printf '%s\n' "$_cur_files" >> "$_clusters"
    }

    _cur_key=""
    _cur_files=""
    _cur_paths=""
    while IFS=$(printf '\t') read -r _key _rel _abs; do
        [ -n "$_key" ] || continue
        if [ "$_key" != "$_cur_key" ]; then
            _flush_cluster
            _cur_key="$_key"
            _cur_files="$_rel"
            _cur_paths="$_abs"
        else
            _cur_files="$_cur_files
$_rel"
            _cur_paths="$_cur_paths
$_abs"
        fi
    done < "$_sorted"
    _flush_cluster
    rm -f "$_sorted"

    printf '\nMemory Hive -- dedup candidates\n'
    printf '%s\n\n' '------------------------------'

    if [ ! -s "$_clusters" ]; then
        rm -f "$_clusters"
        if [ "$_strict" -eq 1 ]; then
            printf 'No clusters above %d%% first-paragraph overlap (scanned %d files).\n\n' \
                "$_threshold" "$_file_count"
        else
            printf 'No near-duplicates found (scanned %d files).\n\n' "$_file_count"
        fi
        return 0
    fi

    _cluster_n=0
    _files_total=0
    _state=0
    _cur_disp=""
    _cur_lines=""
    while IFS= read -r _line; do
        if [ "$_line" = "===CLUSTER===" ]; then
            if [ "$_state" -eq 2 ]; then
                _cluster_n=$((_cluster_n + 1))
                _n=$(printf '%s\n' "$_cur_lines" | grep -c .)
                _files_total=$((_files_total + _n))
                printf 'Cluster %d (%d entries, normalized title: "%s"):\n' \
                    "$_cluster_n" "$_n" "$_cur_disp"
                printf '%s\n' "$_cur_lines" | while IFS= read -r _ln; do
                    [ -n "$_ln" ] && printf '  %s\n' "$_ln"
                done
                printf '\n'
            fi
            _state=1
            _cur_disp=""
            _cur_lines=""
            continue
        fi
        if [ "$_state" -eq 1 ]; then
            _cur_disp="$_line"
            _state=2
            continue
        fi
        if [ "$_state" -eq 2 ]; then
            if [ -z "$_cur_lines" ]; then
                _cur_lines="$_line"
            else
                _cur_lines="$_cur_lines
$_line"
            fi
        fi
    done < "$_clusters"
    if [ "$_state" -eq 2 ] && [ -n "$_cur_disp" ]; then
        _cluster_n=$((_cluster_n + 1))
        _n=$(printf '%s\n' "$_cur_lines" | grep -c .)
        _files_total=$((_files_total + _n))
        printf 'Cluster %d (%d entries, normalized title: "%s"):\n' \
            "$_cluster_n" "$_n" "$_cur_disp"
        printf '%s\n' "$_cur_lines" | while IFS= read -r _ln; do
            [ -n "$_ln" ] && printf '  %s\n' "$_ln"
        done
        printf '\n'
    fi
    rm -f "$_clusters"

    printf '%d cluster(s) found, %d files involved (scanned %d).\n\n' \
        "$_cluster_n" "$_files_total" "$_file_count"
    if [ "$_strict" -eq 1 ]; then
        printf 'Filter: --strict, threshold %d%% first-paragraph overlap.\n\n' "$_threshold"
    fi
    printf 'Curator next step:\n'
    printf '  Pick the strongest entry per cluster, promote it to learnings/distilled/,\n'
    printf '  and archive (or merge) the others. Raw files were not modified.\n\n'

    return 0
}


# --- dispatch ----------------------------------------------------------------

if [ $# -eq 0 ]; then
    mh_help
    exit 0
fi

_verb="$1"
shift
case "$_verb" in
    add)      mh_add "$@" ;;
    list|ls)  mh_list ;;
    archive)  mh_archive "$@" ;;
    role)     mh_role "$@" ;;
    rename)   mh_rename "$@" ;;
    register) _mh_require_install; mh_register; mh_citations >/dev/null 2>&1 || true ;;
    citations|cite) _mh_require_install; mh_citations ;;
    doctor)   mh_doctor "$@" ;;
    setup)    mh_setup ;;
    apply)    _mh_require_install; mh_apply "$@" ;;
    stats)    mh_stats ;;
    watch)    mh_watch ;;
    tail)     mh_tail "$@" ;;
    promote)  mh_promote "$@" ;;
    confidence) mh_confidence "$@" ;;
    tag)      mh_tag "$@" ;;
    tags)     mh_tags "$@" ;;
    stale)    mh_stale "$@" ;;
    checkpoint) mh_checkpoint "$@" ;;
    diff)     mh_diff "$@" ;;
    dedup)    mh_dedup "$@" ;;
    query|search) mh_query "$@" ;;
    help|-h|--help) mh_help ;;
    *)
        printf 'Unknown command: %s\n\n' "$_verb" >&2
        mh_help >&2
        exit 2
        ;;
esac
